# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
.venv/
venv/
env/

# 环境变量与密钥（绝不入库）
.env
.env.local
*.key

# 运行时存储（含客户数据，绝不入库）
/storage/*
!/storage/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# 测试
.pytest_cache/
.pytest_tmp/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# 临时
output/
*.tmp
*.log
*.DS_Store
Thumbs.db

# 样本（敏感，仅本地）
samples/
!samples/.gitkeep

# 大文件
*.pdf
!tests/fixtures/*.pdf
!docs/**/*.pdf

# 备份文件
*.bak
*.bak-*
*.backup
*~

# 数据库文件
*.db

# scripts 输出产物
scripts/*.txt
scripts/*.json
scripts/*.xlsx
scripts/*.pdf

# storage 根级数据文件（防漏网）
/storage/*.json
/storage/*.txt
/storage/*.xlsx
/storage/*.pdf
/storage/*.db
