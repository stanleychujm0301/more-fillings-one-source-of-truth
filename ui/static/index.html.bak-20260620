<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KPMG Hackathon - A+H Consistency Checker</title>
    <style>
        :root {
            --bg: #F7F8FA;
            --bg-warm: #EEF1F6;
            --surface: #FFFFFF;
            --surface-hover: #F5F7FA;
            --text: #0B1628;
            --text-secondary: #4A5568;
            --text-tertiary: #94A3B8;
            --border: #D9DFE8;
            --border-light: #E8ECF2;
            --shadow-sm: 0 1px 2px rgba(0,51,141,0.04);
            --shadow: 0 1px 3px rgba(0,51,141,0.06), 0 1px 2px rgba(0,51,141,0.04);
            --shadow-md: 0 4px 6px rgba(0,51,141,0.06), 0 2px 4px rgba(0,51,141,0.04);
            --shadow-lg: 0 10px 25px rgba(0,51,141,0.08), 0 4px 10px rgba(0,51,141,0.04);
            --kpmg-blue: #00338D;
            --kpmg-blue-bright: #1A56D6;
            --accent: #00338D;
            --accent-light: #E8EEFB;
            --accent-hover: #002A73;
            --teal: #00A3A1;
            --teal-light: #E6F7F7;
            --blue: #00338D;
            --blue-light: #E8EEFB;
            --critical: #C42B2B;
            --critical-bg: #FEF2F2;
            --critical-border: #FECACA;
            --high: #C2651E;
            --high-bg: #FFF7ED;
            --high-border: #FED7AA;
            --medium: #A16207;
            --medium-bg: #FEFCE8;
            --medium-border: #FDE68A;
            --low: #2563EB;
            --low-bg: #EFF6FF;
            --low-border: #BFDBFE;
            --info: #71717A;
            --info-bg: #F4F4F5;
            --info-border: #E4E4E7;
            --success: #16A34A;
            --success-bg: #F0FDF4;
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --font-sans: 'Microsoft YaHei', '微软雅黑', Arial, sans-serif;
            --font-serif: 'Microsoft YaHei', '微软雅黑', Arial, sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: var(--font-sans);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── Header ── */
        .header {
            background: var(--surface);
            border-bottom: 1px solid var(--border-light);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header-inner {
            max-width: 1440px;
            margin: 0 auto;
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .brand {
            display: flex;
            align-items: baseline;
            gap: 0.75rem;
        }
        .brand-title {
            font-family: var(--font-serif);
            font-size: 1.25rem;
            color: var(--kpmg-blue);
            font-weight: 700;
            line-height: 1.2;
        }
        .brand-sub {
            font-size: 0.72rem;
            color: var(--text-tertiary);
            font-weight: 400;
            margin-left: 0.5rem;
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 5px 14px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 500;
            background: var(--bg-warm);
            color: var(--text-secondary);
            border: 1px solid var(--border);
            transition: all 0.3s;
        }
        .status-badge .dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--text-tertiary);
            transition: all 0.3s;
        }
        .status-badge.processing {
            background: var(--teal-light);
            color: var(--teal);
            border-color: rgba(42,143,141,0.2);
        }
        .status-badge.processing .dot {
            background: var(--teal);
            animation: breathe 2s ease-in-out infinite;
        }
        .status-badge.done {
            background: var(--success-bg);
            color: var(--success);
            border-color: rgba(22,163,74,0.15);
        }
        .status-badge.done .dot { background: var(--success); }
        .status-badge.error {
            background: var(--critical-bg);
            color: var(--critical);
            border-color: var(--critical-border);
        }
        .status-badge.error .dot { background: var(--critical); }
        @keyframes breathe { 0%,100%{opacity:1} 50%{opacity:0.3} }

        /* ── Layout ── */
        .main {
            max-width: 1440px;
            margin: 0 auto;
            padding: 1.25rem 1.5rem 2rem;
        }
        .workspace-layout {
            display: grid;
            grid-template-columns: minmax(400px, 460px) minmax(0, 1fr);
            gap: 1rem;
            align-items: start;
        }
        .control-rail {
            position: sticky;
            top: 88px;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            max-height: calc(100vh - 104px);
            min-width: 0;
        }
        .work-area {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .control-rail .upload-card,
        .control-rail .history-card,
        .work-area .progress-card,
        .work-area .dashboard,
        .work-area .results-wrap {
            margin-bottom: 0;
        }

        /* ── Upload ── */
        .upload-card {
            background: var(--surface);
            border-radius: var(--radius-xl);
            padding: 2rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            margin-bottom: 1.5rem;
        }
        .upload-heading {
            font-family: var(--font-serif);
            font-size: 1.35rem;
            color: var(--text);
            margin-bottom: 0.25rem;
        }
        .upload-desc {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
        }
        .company-field {
            margin-bottom: 1.25rem;
        }
        .company-field label {
            display: block;
            font-size: 0.78rem;
            color: var(--text-secondary);
            font-weight: 700;
            margin-bottom: 0.4rem;
        }
        .company-field input {
            width: 100%;
            min-height: 42px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            background: var(--surface);
            color: var(--text);
            font: inherit;
            font-size: 0.86rem;
            padding: 0.65rem 0.78rem;
            outline: none;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }
        .company-field input:focus {
            border-color: var(--kpmg-blue);
            box-shadow: 0 0 0 3px rgba(0,51,141,0.08);
            background: white;
        }
        .company-field.field-missing input {
            border-color: #C81E1E;
            background: #FFF5F5;
            box-shadow: 0 0 0 3px rgba(200,30,30,0.1);
        }
        .company-helper {
            margin-top: 0.34rem;
            color: var(--text-tertiary);
            font-size: 0.68rem;
            line-height: 1.35;
        }
        .mode-field {
            margin-bottom: 1rem;
        }
        .mode-label {
            display: block;
            font-size: 0.78rem;
            color: var(--text-secondary);
            font-weight: 700;
            margin-bottom: 0.45rem;
        }
        .mode-control {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.45rem;
            padding: 0.25rem;
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            background: var(--bg);
        }
        .mode-option {
            position: relative;
            min-width: 0;
        }
        .mode-option input {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }
        .mode-option span {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 34px;
            border-radius: 6px;
            color: var(--text-secondary);
            font-size: 0.76rem;
            font-weight: 700;
            text-align: center;
            transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
        }
        .mode-option input:checked + span {
            background: var(--kpmg-blue);
            color: #fff;
            box-shadow: 0 4px 10px rgba(0,51,141,0.16);
        }
        .upload-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        @media (max-width: 768px) { .upload-grid { grid-template-columns: 1fr; } }

        .dropzone {
            border: 1.5px dashed var(--border);
            border-radius: var(--radius-lg);
            padding: 2.5rem 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s ease;
            position: relative;
            background: var(--bg);
        }
        .dropzone:hover {
            border-color: var(--kpmg-blue);
            background: var(--accent-light);
        }
        .dropzone.drag-over {
            border-color: var(--kpmg-blue);
            background: var(--accent-light);
            transform: scale(1.01);
        }
        .dropzone.has-file {
            border-color: var(--teal);
            border-style: solid;
            background: var(--teal-light);
        }
        .dropzone.field-missing {
            border-color: #C81E1E;
            background: #FFF5F5;
        }
        .shake {
            animation: fieldShake 0.34s ease;
        }
        @keyframes fieldShake {
            0%, 100% { transform: translateX(0); }
            18%, 54%, 90% { transform: translateX(-5px); }
            36%, 72% { transform: translateX(5px); }
        }
        .dropzone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .dz-icon {
            width: 40px; height: 40px;
            margin: 0 auto 0.75rem;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            color: var(--text-tertiary);
            transition: all 0.25s;
        }
        .dropzone:hover .dz-icon {
            background: var(--surface);
            border-color: var(--kpmg-blue);
            color: var(--kpmg-blue);
        }
        .dropzone.has-file .dz-icon {
            background: var(--surface);
            border-color: var(--teal);
            color: var(--teal);
        }
        .dz-icon svg { width: 18px; height: 18px; }
        .dz-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.2rem;
        }
        .dz-hint {
            font-size: 0.78rem;
            color: var(--text-tertiary);
        }
        .dz-file {
            font-size: 0.78rem;
            color: var(--teal);
            font-weight: 500;
            margin-top: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.3rem;
        }
        .dz-file svg { width: 14px; height: 14px; }

        .btn-primary {
            background: var(--accent);
            color: white;
            border: none;
            padding: 0.7rem 2rem;
            border-radius: 100px;
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .btn-primary:hover:not(:disabled):not([aria-disabled="true"]) {
            background: var(--accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0,51,141,0.25);
        }
        .btn-primary:active:not(:disabled):not([aria-disabled="true"]) { transform: translateY(0); }
        .btn-primary[aria-disabled="true"]:not(:disabled) {
            opacity: 0.46;
            cursor: pointer;
            box-shadow: none;
        }
        .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
        .control-rail .upload-card {
            padding: 1rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
        }
        .control-rail .upload-heading {
            font-size: 1rem;
        }
        .control-rail .upload-desc {
            margin-bottom: 0.7rem;
            font-size: 0.74rem;
            line-height: 1.45;
        }
        .control-rail .upload-grid {
            grid-template-columns: 1fr;
            gap: 0.6rem;
            margin-bottom: 0.7rem;
        }
        .control-rail .dropzone {
            min-height: 108px;
            padding: 0.8rem 0.85rem;
            border-radius: var(--radius);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .control-rail .dz-icon {
            width: 30px;
            height: 30px;
            margin-bottom: 0.4rem;
        }
        .control-rail .dz-title {
            font-size: 0.82rem;
        }
        .control-rail .dz-hint {
            font-size: 0.72rem;
        }
        .control-rail .dz-file {
            max-width: 100%;
            justify-content: center;
            overflow: hidden;
            margin-top: 0.55rem;
        }
        .control-rail .dz-file span {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .control-rail .btn-primary {
            width: 100%;
            justify-content: center;
            min-height: 40px;
            padding: 0.6rem 1rem;
        }
        .spinner {
            width: 16px; height: 16px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── History ── */
        .history-card {
            background: var(--surface);
            border-radius: var(--radius-xl);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            margin-bottom: 1.5rem;
            display: block;
        }
        .history-card.has-data { display: block; }
        .control-rail .history-card {
            padding: 0.9rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            flex: 1;
            min-height: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .control-rail .history-card.has-data {
            display: flex;
            flex-direction: column;
        }
        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        .history-title {
            font-family: var(--font-serif);
            font-size: 1.1rem;
            color: var(--text);
        }
        .history-count {
            font-size: 0.75rem;
            color: var(--text-tertiary);
        }
        .history-list {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            max-height: 240px;
            overflow-y: auto;
        }
        .history-empty {
            border: 1px dashed var(--border);
            border-radius: var(--radius);
            padding: 0.8rem;
            color: var(--text-tertiary);
            font-size: 0.76rem;
            line-height: 1.45;
            background: #F8FAFD;
        }
        .control-rail .history-list {
            flex: 1;
            min-height: 0;
            max-height: none;
        }
        .history-item {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            justify-content: flex-start;
            padding: 0.75rem 1rem;
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            cursor: pointer;
            transition: all 0.15s;
            gap: 0.42rem;
        }
        .control-rail .history-item {
            padding: 0.6rem 0.7rem;
            gap: 0.38rem;
        }
        .history-item:hover {
            background: var(--accent-light);
            border-color: rgba(0,51,141,0.15);
        }
        .history-item .hi-row-main {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.55rem;
            min-width: 0;
            width: 100%;
        }
        .history-item .hi-main {
            display: flex;
            align-items: flex-start;
            gap: 0.55rem;
            flex: 1;
            min-width: 0;
        }
        .hi-badge {
            width: 8px; height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .hi-badge.done { background: var(--success); }
        .hi-badge.partial { background: var(--medium); }
        .hi-badge.failed { background: var(--critical); }
        .hi-info {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 0.1rem;
        }
        .hi-company-line {
            display: flex;
            align-items: center;
            gap: 0.48rem;
            min-width: 0;
        }
        .history-company {
            font-size: 0.82rem;
            font-weight: 800;
            color: var(--text);
            line-height: 1.25;
            overflow-wrap: anywhere;
        }
        .control-rail .history-company {
            font-size: 0.78rem;
        }
        .hi-files {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text);
            display: flex;
            flex-direction: column;
            gap: 0.12rem;
            min-width: 0;
            line-height: 1.25;
        }
        .control-rail .hi-files {
            font-size: 0.75rem;
        }
        .hi-file-line {
            display: flex;
            align-items: flex-start;
            gap: 0.34rem;
            min-width: 0;
        }
        .hi-file-tag {
            flex: 0 0 auto;
            min-width: 1.1rem;
            font-size: 0.66rem;
            line-height: 1.25;
            font-weight: 700;
            color: var(--kpmg-blue);
        }
        .hi-file-name {
            min-width: 0;
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
            line-height: 1.25;
        }
        .hi-time {
            display: block;
            font-size: 0.7rem;
            color: var(--text-tertiary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.2;
        }
        .hi-stats {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            flex-wrap: wrap;
            font-variant-numeric: tabular-nums;
        }
        .hi-row-stats {
            width: 100%;
            padding-left: 1.1rem;
        }
        .hi-stat {
            font-size: 0.7rem;
            color: var(--text-secondary);
            white-space: nowrap;
            font-variant-numeric: tabular-nums;
        }
        .hi-stat.critical { color: var(--critical); font-weight: 600; }
        .hi-stat.high { color: var(--high); font-weight: 600; }
        .control-rail .hi-stats {
            gap: 0.35rem;
        }
        .control-rail .hi-row-stats {
            padding-left: 1rem;
        }
        .control-rail .hi-stat,
        .control-rail .hi-reload {
            font-size: 0.66rem;
        }
        .hi-reload {
            font-size: 0.7rem;
            color: var(--kpmg-blue);
            font-weight: 600;
            white-space: nowrap;
            padding: 3px 8px;
            border-radius: 100px;
            background: var(--accent-light);
            transition: all 0.15s;
            flex-shrink: 0;
        }
        .history-item:hover .hi-reload {
            background: var(--kpmg-blue);
            color: white;
        }

        /* ── Progress ── */
        .progress-card {
            background: var(--surface);
            border-radius: var(--radius-xl);
            padding: 1.75rem 2rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            margin-bottom: 1.5rem;
            display: none;
        }
        .progress-card.active { display: block; animation: fadeUp 0.4s ease; }
        .work-area .progress-card {
            padding: 1rem 1.1rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
        }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

        .progress-track {
            background: var(--bg-warm);
            border-radius: 100px;
            height: 6px;
            overflow: hidden;
            margin-bottom: 1.25rem;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--kpmg-blue), var(--teal));
            border-radius: 100px;
            transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
            width: 0%;
        }
        .stages {
            display: flex;
            justify-content: space-between;
        }
        .stage {
            flex: 1;
            text-align: center;
            padding: 0.5rem 0.25rem;
            border-radius: 8px;
            font-size: 0.72rem;
            font-weight: 500;
            color: var(--text-tertiary);
            transition: all 0.35s;
            position: relative;
        }
        .stage::before {
            content: '';
            display: block;
            width: 24px; height: 24px;
            margin: 0 auto 0.4rem;
            border-radius: 50%;
            background: var(--bg-warm);
            border: 2px solid var(--border);
            transition: all 0.35s;
        }
        .stage.active { color: var(--kpmg-blue); }
        .stage.active::before {
            background: var(--accent-light);
            border-color: var(--kpmg-blue);
        }
        .stage.completed { color: var(--success); }
        .stage.completed::before {
            background: var(--success-bg);
            border-color: var(--success);
        }
        .stage.error { color: var(--critical); }
        .stage.error::before {
            background: var(--critical-bg);
            border-color: var(--critical);
        }
        .progress-msg {
            text-align: center;
            font-size: 0.82rem;
            color: var(--text-secondary);
            margin-top: 0.75rem;
        }

        .warning-panel {
            display: none;
            margin-bottom: 1rem;
            background: #fff8e6;
            border: 1px solid #f3c969;
            border-left: 4px solid #d98c00;
            border-radius: var(--radius);
            padding: 0.85rem 1rem;
            box-shadow: var(--shadow-sm);
        }
        .warning-panel.active { display: block; animation: fadeUp 0.25s ease; }
        .warning-panel .warn-title {
            font-size: 0.82rem;
            font-weight: 700;
            color: #7a4b00;
            margin-bottom: 0.45rem;
        }
        .warning-panel .warn-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 0.55rem;
        }
        .warning-panel .warn-item {
            background: rgba(255,255,255,0.72);
            border: 1px solid rgba(217,140,0,0.18);
            border-radius: 8px;
            padding: 0.55rem 0.65rem;
            font-size: 0.76rem;
            color: #5b3b00;
            line-height: 1.45;
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            align-items: flex-start;
        }
        .warning-panel .warn-item strong {
            display: block;
            font-size: 0.7rem;
            color: #9a6400;
            margin-bottom: 0.2rem;
        }
        .warn-action,
        .row-review-btn {
            border: 1px solid #D4E0F7;
            background: var(--accent-light);
            color: var(--kpmg-blue);
            border-radius: 7px;
            padding: 0.28rem 0.48rem;
            font-size: 0.68rem;
            font-weight: 700;
            white-space: nowrap;
            cursor: pointer;
        }
        .warn-action:hover,
        .row-review-btn:hover {
            background: var(--kpmg-blue);
            color: #FFFFFF;
        }

        /* ── Audit Summary ── */
        .audit-strip {
            display: none;
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            border-left: 4px solid var(--medium);
            border-radius: var(--radius-lg);
            padding: 1rem 1.1rem;
            gap: 1rem;
            align-items: stretch;
            margin-bottom: 0.85rem;
        }
        .audit-strip.active {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            animation: fadeUp 0.3s ease;
        }
        .audit-strip.clean { border-left-color: var(--success); }
        .audit-strip.risk { border-left-color: var(--critical); }
        .audit-strip.stale { border-left-color: var(--medium); }
        .audit-strip.empty { border-left-color: var(--medium); }
        .audit-main {
            min-width: 0;
            display: grid;
            gap: 0.55rem;
        }
        .audit-kicker {
            color: var(--kpmg-blue);
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }
        .audit-company {
            display: inline-flex;
            align-items: baseline;
            gap: 0.42rem;
            min-width: 0;
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.3;
        }
        .audit-company span {
            flex: 0 0 auto;
            color: var(--text-tertiary);
            font-weight: 700;
        }
        .audit-company strong {
            min-width: 0;
            color: var(--kpmg-blue);
            font-size: inherit;
            font-weight: 800;
            overflow-wrap: anywhere;
        }
        .audit-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
        }
        .audit-title {
            color: var(--text);
            font-size: 1.08rem;
            font-weight: 800;
            line-height: 1.25;
        }
        .audit-copy {
            color: var(--text-secondary);
            font-size: 0.82rem;
            line-height: 1.45;
            margin-top: 0.18rem;
        }
        .audit-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            border: 1px solid var(--medium-border);
            background: var(--medium-bg);
            color: var(--medium);
            border-radius: 999px;
            padding: 0.35rem 0.6rem;
            font-size: 0.72rem;
            font-weight: 800;
            white-space: nowrap;
        }
        .audit-pill::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: currentColor;
        }
        .audit-pill.clean {
            background: var(--success-bg);
            color: var(--success);
            border-color: rgba(22,163,74,0.25);
        }
        .audit-pill.risk {
            background: var(--critical-bg);
            color: var(--critical);
            border-color: var(--critical-border);
        }
        .audit-pill.stale {
            background: var(--medium-bg);
            color: var(--medium);
            border-color: var(--medium-border);
        }
        .audit-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }
        .audit-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.32rem 0.52rem;
            border: 1px solid var(--border-light);
            border-radius: 999px;
            background: #F8FAFD;
            color: var(--text-secondary);
            font-size: 0.72rem;
            line-height: 1.2;
            white-space: nowrap;
        }
        .audit-chip strong {
            color: var(--text);
            font-weight: 800;
        }
        .audit-status {
            display: flex;
            align-items: flex-start;
            justify-content: flex-end;
            min-width: 220px;
            padding-top: 0.15rem;
        }

        /* ── Dashboard ── */
        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(132px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            display: none;
        }
        .dashboard.active { display: grid; animation: fadeUp 0.4s ease; }
        @media (max-width: 1024px) { .dashboard { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 640px) { .dashboard { grid-template-columns: repeat(2, 1fr); } }

        .metric-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 1.25rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-light);
            transition: all 0.2s;
        }
        .metric-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
        .metric-label {
            font-size: 0.72rem;
            color: var(--text-tertiary);
            font-weight: 500;
            margin-bottom: 0.5rem;
            letter-spacing: 0.02em;
        }
        .metric-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text);
            line-height: 1.2;
        }
        .metric-sub {
            margin-top: 0.35rem;
            color: var(--text-tertiary);
            font-size: 0.7rem;
            line-height: 1.35;
        }
        .metric-card.critical .metric-value { color: var(--critical); }
        .metric-card.high .metric-value { color: var(--high); }
        .metric-card.accent .metric-value { color: var(--kpmg-blue); }
        .metric-card.duration .metric-value { color: var(--kpmg-blue); font-size: 1.3rem; }

        /* ── Filters ── */
        .filter-bar {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
            align-items: center;
        }
        .filter-group {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .filter-group > label {
            font-size: 0.78rem;
            color: var(--text-secondary);
            font-weight: 600;
            margin-right: 0.25rem;
        }
        .chip {
            padding: 5px 12px;
            border-radius: 100px;
            font-size: 0.75rem;
            cursor: pointer;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            transition: all 0.15s;
            user-select: none;
            font-weight: 500;
        }
        .chip:hover:not(.active) {
            background: var(--bg-warm);
            border-color: var(--text-tertiary);
        }
        .chip.active {
            background: var(--kpmg-blue);
            color: white;
            border-color: var(--kpmg-blue);
        }

        /* ── Results ── */
        .results-wrap { display: none; }
        .results-wrap.active { display: block; animation: fadeUp 0.4s ease; }

        .table-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            overflow: hidden;
        }
        .table-scroll { overflow-x: auto; }
        .diff-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 0.82rem;
        }
        .diff-table thead { background: var(--bg); }
        .diff-table th {
            padding: 0.7rem 1rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
            position: sticky;
            top: 0;
            background: var(--bg);
            z-index: 10;
        }
        .diff-table td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
            transition: background 0.1s;
        }
        .diff-table tbody tr {
            cursor: pointer;
            transition: background 0.1s;
        }
        .diff-table tbody tr:hover { background: var(--surface-hover); }
        .diff-table tbody tr.selected { background: var(--accent-light); }
        .diff-table tbody tr.selected td { border-bottom-color: #C5D4EE; }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 9px;
            border-radius: 100px;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            white-space: nowrap;
        }
        .badge-critical { background: var(--critical-bg); color: var(--critical); }
        .badge-high { background: var(--high-bg); color: var(--high); }
        .badge-medium { background: var(--medium-bg); color: var(--medium); }
        .badge-low { background: var(--low-bg); color: var(--low); }
        .badge-info { background: var(--info-bg); color: var(--info); }
        .badge-numeric { background: #EDE9FE; color: #6D28D9; }
        .badge-standard { background: var(--teal-light); color: var(--teal); }
        .badge-disclosure { background: #F3E8FF; color: #7C3AED; }
        .badge-chart { background: #FCE7F3; color: #BE185D; }
        .badge-cross_check { background: #DBEAFE; color: #1D4ED8; }
        .badge-internal { background: #FEE2E2; color: #B91C1C; }
        .badge-real { background: var(--critical-bg); color: var(--critical); }
        .badge-expected { background: var(--success-bg); color: var(--success); }
        .badge-unresolved { background: var(--medium-bg); color: var(--medium); }

        .col-narrow { width: 48px; }
        .col-sev { width: 85px; }
        .col-type { width: 95px; }
        .col-triage { width: 95px; }
        .col-topic { min-width: 200px; max-width: 320px; }
        .col-explanation { min-width: 300px; max-width: 460px; }
        .col-num { width: 130px; text-align: right !important; }
        .col-pages { width: 100px; }

        .cell-num {
            font-variant-numeric: tabular-nums;
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-align: right;
        }
        .cell-num strong {
            color: var(--text);
            font-weight: 600;
        }
        .topic-cell {
            font-weight: 500;
            color: var(--text);
            line-height: 1.4;
        }
        .topic-cell .sub {
            font-size: 0.72rem;
            color: var(--text-tertiary);
            font-weight: 400;
            margin-top: 1px;
        }
        .explanation-cell {
            display: grid;
            gap: 0.18rem;
            line-height: 1.45;
        }
        .explanation-head {
            color: var(--text);
            font-size: 0.86rem;
            font-weight: 750;
        }
        .explanation-issue {
            color: var(--text-secondary);
            font-size: 0.76rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .explanation-legacy {
            color: var(--medium);
            font-size: 0.68rem;
            font-weight: 700;
        }
        .page-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.2rem;
            font-size: 0.72rem;
            color: var(--text-tertiary);
            font-variant-numeric: tabular-nums;
        }
        .page-tag svg { width: 12px; height: 12px; }

        .empty-state {
            text-align: center;
            padding: 3.5rem 2rem;
            color: var(--text-tertiary);
        }
        .empty-state svg { width: 40px; height: 40px; margin-bottom: 0.75rem; opacity: 0.3; }
        .empty-state p { font-size: 0.88rem; }

        .view-tabs {
            display: flex;
            gap: 0.4rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }
        .view-tab {
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            border-radius: 100px;
            padding: 0.5rem 0.95rem;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
        }
        .view-tab:hover:not(.active) {
            background: var(--bg-warm);
            border-color: var(--text-tertiary);
        }
        .view-tab.active {
            background: var(--kpmg-blue);
            border-color: var(--kpmg-blue);
            color: white;
        }
        .tab-count {
            display: inline-flex;
            min-width: 1.25rem;
            justify-content: center;
            border-radius: 999px;
            padding: 0.04rem 0.35rem;
            background: rgba(0,51,141,0.08);
            color: var(--text-secondary);
            font-size: 0.66rem;
            font-weight: 800;
            line-height: 1.35;
        }
        .view-tab.active .tab-count {
            background: rgba(255,255,255,0.22);
            color: #FFFFFF;
        }
        .view-pane { display: none; }
        .view-pane.active { display: block; animation: fadeUp 0.25s ease; }
        .profile-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.75rem;
            margin-bottom: 1rem;
        }
        @media (max-width: 1024px) { .profile-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 640px) { .profile-grid { grid-template-columns: 1fr; } }
        .profile-section {
            background: var(--surface);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 1rem;
        }
        .profile-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border-light);
            background: var(--bg);
        }
        .profile-section-title {
            font-family: var(--font-serif);
            color: var(--text);
            font-size: 1rem;
            font-weight: 700;
        }
        .profile-section-count {
            font-size: 0.72rem;
            color: var(--text-tertiary);
            white-space: nowrap;
        }
        .profile-scroll {
            overflow: auto;
            max-height: 520px;
        }
        .profile-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 0.78rem;
        }
        .profile-table th {
            position: sticky;
            top: 0;
            z-index: 5;
            background: var(--bg);
            text-align: left;
            color: var(--text-secondary);
            font-size: 0.68rem;
            font-weight: 700;
            padding: 0.65rem 0.8rem;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }
        .profile-table td {
            padding: 0.65rem 0.8rem;
            border-bottom: 1px solid var(--border-light);
            vertical-align: top;
            color: var(--text-secondary);
        }
        .profile-table .main-text {
            color: var(--text);
            font-weight: 600;
        }
        .profile-table .snippet {
            max-width: 420px;
            color: var(--text-secondary);
            line-height: 1.5;
        }
        .profile-table .num {
            text-align: right;
            font-variant-numeric: tabular-nums;
            white-space: nowrap;
        }
        .structure-tree {
            padding: 1rem 1.25rem;
            max-height: 520px;
            overflow: auto;
        }
        .structure-node {
            border-left: 2px solid var(--border-light);
            padding-left: 0.75rem;
            margin: 0.45rem 0;
            color: var(--text-secondary);
            font-size: 0.8rem;
        }
        .structure-node .node-title {
            color: var(--text);
            font-weight: 600;
        }
        .structure-node .node-meta {
            color: var(--text-tertiary);
            font-size: 0.72rem;
            margin-left: 0.25rem;
        }
        .text-muted {
            color: var(--text-tertiary);
            font-size: 0.82rem;
            padding: 1.5rem;
            text-align: center;
        }
        .evidence-table .snippet {
            max-width: 520px;
        }

        /* ── Detail Panel ── */
        .detail-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            margin-top: 1rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            display: none;
            overflow: hidden;
        }
        .detail-card.active { display: block; animation: fadeUp 0.3s ease; }

        .detail-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 1.5rem 1.75rem;
            border-bottom: 1px solid var(--border-light);
            background: var(--bg);
        }
        .detail-title-wrap h3 {
            font-family: var(--font-serif);
            font-size: 1.15rem;
            color: var(--text);
            margin-bottom: 0.25rem;
        }
        .detail-title-wrap .meta {
            font-size: 0.72rem;
            color: var(--text-tertiary);
        }
        .detail-badges { display: flex; gap: 0.35rem; }
        .detail-body {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 0;
        }
        @media (max-width: 1024px) { .detail-body { grid-template-columns: 1fr; } }
        .detail-main {
            padding: 1.5rem 1.75rem;
            border-right: 1px solid var(--border-light);
        }
        @media (max-width: 1024px) {
            .detail-main { border-right: none; border-bottom: 1px solid var(--border-light); }
        }
        .detail-side { padding: 1.5rem 1.75rem; }

        .section-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-tertiary);
            margin-bottom: 0.625rem;
            font-weight: 600;
        }

        .desc-text {
            font-size: 0.88rem;
            color: var(--text-secondary);
            line-height: 1.7;
            margin-bottom: 1.5rem;
        }

        .compare-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }
        .compare-box {
            background: var(--bg);
            border-radius: var(--radius);
            padding: 1rem;
            border: 1px solid var(--border-light);
            position: relative;
        }
        .side-label {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 0.35rem;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .compare-box.a-side .side-label { color: var(--kpmg-blue); }
        .compare-box.h-side .side-label { color: var(--teal); }
        .side-value {
            font-size: 1.15rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--text);
            letter-spacing: -0.02em;
        }
        .compare-box.a-side .side-value { color: var(--kpmg-blue); }
        .compare-box.h-side .side-value { color: var(--teal); }
        .side-delta {
            font-size: 0.72rem;
            color: var(--text-tertiary);
            margin-top: 0.25rem;
            font-variant-numeric: tabular-nums;
        }

        .reasoning-card {
            background: var(--blue-light);
            border-radius: var(--radius);
            padding: 1rem;
            border: 1px solid rgba(74,111,165,0.12);
            margin-bottom: 1rem;
        }
        .r-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.625rem;
        }
        .r-badge {
            padding: 3px 9px;
            border-radius: 100px;
            font-size: 0.68rem;
            font-weight: 600;
        }
        .r-badge.expected { background: var(--success-bg); color: var(--success); }
        .r-badge.unexpected { background: var(--high-bg); color: var(--high); }
        .r-confidence { font-size: 0.72rem; color: var(--text-tertiary); }
        .reasoning-card p {
            font-size: 0.85rem;
            color: var(--text);
            line-height: 1.65;
        }
        .reasoning-card .citations {
            margin-top: 0.625rem;
            padding-top: 0.625rem;
            border-top: 1px solid rgba(74,111,165,0.1);
        }
        .reasoning-card .citations li {
            font-size: 0.78rem;
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
            list-style: none;
            padding-left: 1rem;
            position: relative;
        }
        .reasoning-card .citations li::before {
            content: '';
            position: absolute;
            left: 0; top: 0.5rem;
            width: 5px; height: 5px;
            border-radius: 50%;
            background: var(--blue);
        }

        .evidence-list { display: flex; flex-direction: column; gap: 0.5rem; }
        .ev-item {
            background: var(--bg);
            border-radius: var(--radius);
            padding: 0.875rem 1rem;
            border: 1px solid var(--border-light);
            border-left: 3px solid var(--kpmg-blue);
            transition: all 0.15s;
        }
        .ev-item:hover { background: var(--surface-hover); }
        .ev-item.h-side { border-left-color: var(--teal); }
        .ev-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.35rem;
        }
        .ev-side {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            color: var(--kpmg-blue);
        }
        .ev-item.h-side .ev-side { color: var(--teal); }
        .ev-page {
            font-size: 0.68rem;
            color: var(--text-tertiary);
            font-variant-numeric: tabular-nums;
            display: flex;
            align-items: center;
            gap: 0.2rem;
        }
        .ev-page svg { width: 10px; height: 10px; }
        .ev-snippet {
            font-size: 0.82rem;
            color: var(--text-secondary);
            line-height: 1.55;
            word-break: break-word;
        }

        .chart-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
        }
        .chart-metric {
            background: var(--bg);
            border-radius: var(--radius);
            padding: 0.75rem;
            border: 1px solid var(--border-light);
            text-align: center;
        }
        .chart-metric .cm-label {
            font-size: 0.65rem;
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 0.25rem;
        }
        .chart-metric .cm-value {
            font-size: 1rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--text);
        }

        /* ── Downloads ── */
        .download-bar {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }
        .btn-dl {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.55rem 1rem;
            border-radius: 100px;
            font-size: 0.82rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.15s;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
        }
        .btn-dl:hover {
            background: var(--accent-light);
            border-color: var(--kpmg-blue);
            color: var(--kpmg-blue);
        }
        .btn-dl svg { width: 14px; height: 14px; }

        /* ── Toast ── */
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 0.875rem 1.25rem;
            border-radius: var(--radius);
            font-weight: 500;
            font-size: 0.85rem;
            z-index: 1000;
            transform: translateX(calc(100% + 40px));
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
            box-shadow: var(--shadow-lg);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            max-width: 420px;
        }
        .toast.show { transform: translateX(0); }
        .toast.success { background: var(--success); color: white; }
        .toast.error { background: var(--critical); color: white; }
        .toast svg { width: 16px; height: 16px; flex-shrink: 0; }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-tertiary); }
        @media (max-width: 1024px) {
            .main {
                padding: 1rem;
            }
            .workspace-layout {
                grid-template-columns: 1fr;
            }
            .control-rail {
                position: static;
                max-height: none;
            }
            .control-rail .history-list {
                max-height: 240px;
            }
            .control-rail .upload-grid {
                grid-template-columns: 1fr 1fr;
            }
            .control-rail .dropzone {
                min-height: 150px;
            }
        }

        @media (max-width: 768px) {
            .header-inner {
                padding: 0 1rem;
            }
            .control-rail .upload-grid {
                grid-template-columns: 1fr;
            }
            .work-area {
                gap: 0.75rem;
            }
        }
        /* Workbench refresh */
        :root {
            --bg: #F3F6FA;
            --surface-hover: #F8FAFC;
            --border: #D5DCE7;
            --border-light: #E4E9F1;
            --shadow-sm: 0 1px 2px rgba(12, 28, 54, 0.04);
            --shadow: 0 1px 2px rgba(12, 28, 54, 0.05);
            --shadow-md: 0 6px 14px rgba(12, 28, 54, 0.08);
            --shadow-lg: 0 18px 48px rgba(12, 28, 54, 0.22);
            --radius: 8px;
            --radius-lg: 10px;
            --radius-xl: 12px;
        }
        body.review-open { overflow: hidden; }
        .header {
            box-shadow: 0 1px 0 rgba(12, 28, 54, 0.05);
        }
        .header-inner {
            height: 58px;
        }
        .brand {
            gap: 0.45rem;
        }
        .brand-title {
            font-size: 1.08rem;
        }
        .brand-sub {
            margin-left: 0;
            font-size: 0.8rem;
        }
        .main {
            padding-top: 1rem;
        }
        .workspace-layout {
            grid-template-columns: minmax(400px, 460px) minmax(0, 1fr);
        }
        .control-rail {
            top: 74px;
            max-height: calc(100vh - 90px);
        }
        .control-rail .upload-card,
        .control-rail .history-card,
        .work-area .progress-card,
        .results-wrap.active,
        .profile-section,
        .table-card,
        .metric-card {
            box-shadow: none;
        }
        .control-rail .upload-card,
        .control-rail .history-card {
            border-color: #DCE3EE;
        }
        .control-rail .upload-card {
            border-top: 3px solid var(--kpmg-blue);
        }
        .upload-heading,
        .history-title,
        .profile-section-title {
            font-family: var(--font-sans);
            letter-spacing: 0;
        }
        .control-rail .dropzone {
            background: #F8FAFD;
            border-style: solid;
        }
        .control-rail .dropzone:hover {
            transform: none;
        }
        .btn-primary,
        .view-tab,
        .chip,
        .btn-dl {
            border-radius: 7px;
        }
        .btn-primary {
            min-height: 42px;
            box-shadow: none;
        }
        .btn-primary:hover:not(:disabled):not([aria-disabled="true"]) {
            box-shadow: 0 7px 16px rgba(0,51,141,0.22);
        }
        .history-item {
            border-radius: 8px;
            background: #FFFFFF;
        }
        .control-rail .history-item {
            align-items: stretch;
        }
        .work-area {
            gap: 0.85rem;
        }
        .launch-panel {
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 0.9rem 1rem;
            min-height: 180px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            align-items: stretch;
        }
        .launch-panel.hidden {
            display: none;
        }
        .launch-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 0.85rem;
        }
        .launch-eyebrow,
        .review-eyebrow {
            color: var(--kpmg-blue);
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }
        .launch-title {
            margin-top: 0.25rem;
            font-size: 1.35rem;
            line-height: 1.25;
            color: var(--text);
        }
        .launch-copy {
            margin-top: 0.45rem;
            color: var(--text-secondary);
            font-size: 0.84rem;
            max-width: 640px;
        }
        .launch-status {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.45rem 0.65rem;
            background: var(--accent-light);
            color: var(--kpmg-blue);
            border: 1px solid #D4E0F7;
            border-radius: 7px;
            font-size: 0.75rem;
            font-weight: 700;
            white-space: nowrap;
        }
        .launch-status::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--kpmg-blue);
        }
        .launch-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.55rem;
        }
        .launch-step {
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            background: #FBFCFE;
            padding: 0.78rem;
        }
        .launch-step span {
            display: inline-flex;
            width: 26px;
            height: 26px;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            background: var(--accent-light);
            color: var(--kpmg-blue);
            font-size: 0.72rem;
            font-weight: 800;
            margin-bottom: 0.65rem;
        }
        .launch-step strong {
            display: block;
            color: var(--text);
            font-size: 0.88rem;
        }
        .launch-step small {
            display: block;
            margin-top: 0.25rem;
            color: var(--text-tertiary);
            font-size: 0.74rem;
            line-height: 1.45;
        }
        .progress-card {
            border-radius: var(--radius-lg);
        }
        .progress-card.active {
            border-left: 3px solid var(--teal);
        }
        .stages {
            gap: 0.35rem;
        }
        .stage {
            background: #F8FAFD;
            border: 1px solid transparent;
        }
        .stage.active {
            background: var(--accent-light);
            border-color: #D4E0F7;
        }
        .stage::before {
            width: 18px;
            height: 18px;
            border-width: 1px;
        }
        .dashboard.active {
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 0.6rem;
        }
        .metric-card {
            border-color: #DCE3EE;
            border-left: 3px solid #CBD5E1;
            padding: 0.85rem 0.95rem;
        }
        .metric-card.critical { border-left-color: var(--critical); }
        .metric-card.high { border-left-color: var(--high); }
        .metric-card.accent { border-left-color: var(--kpmg-blue); }
        .metric-card.duration { border-left-color: var(--teal); }
        .metric-card:hover {
            transform: none;
            box-shadow: var(--shadow-sm);
        }
        .metric-label {
            margin-bottom: 0.35rem;
            letter-spacing: 0;
            text-transform: none;
        }
        .metric-value {
            font-size: 1.35rem;
        }
        .col-action {
            width: 92px;
            text-align: center;
        }
        .results-wrap.active {
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 0.85rem;
        }
        .view-tabs {
            position: sticky;
            top: 58px;
            z-index: 30;
            padding: 0 0 0.75rem;
            margin-bottom: 0.85rem;
            background: linear-gradient(180deg, #FFFFFF 70%, rgba(255,255,255,0));
            border-bottom: 1px solid var(--border-light);
        }
        .view-tab {
            background: #F8FAFD;
            border-color: #DCE3EE;
        }
        .view-tab.active {
            box-shadow: inset 0 -2px 0 rgba(255,255,255,0.25);
        }
        .filter-bar {
            background: #F8FAFD;
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            padding: 0.7rem;
        }
        .profile-section,
        .table-card {
            border-radius: var(--radius);
        }
        .profile-section-header {
            padding: 0.8rem 1rem;
        }
        .diff-table th,
        .profile-table th {
            letter-spacing: 0;
            text-transform: none;
        }
        .diff-table tbody tr:hover,
        .profile-table tbody tr:hover {
            background: #F8FAFD;
        }
        .diff-table tbody tr.selected td {
            background: #EEF4FF;
        }
        .detail-card {
            display: none !important;
        }
        .download-bar {
            justify-content: flex-end;
        }
        .review-overlay {
            position: fixed;
            inset: 0;
            z-index: 1000;
            display: none;
            padding: 1rem;
            background: rgba(8, 18, 34, 0.72);
            backdrop-filter: blur(8px);
        }
        .review-overlay.active {
            display: block;
            animation: fadeUp 0.18s ease;
        }
        .review-shell {
            height: calc(100vh - 2rem);
            background: #F6F8FB;
            border: 1px solid rgba(255,255,255,0.28);
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            display: grid;
            grid-template-rows: auto auto minmax(0, 1fr);
            overflow: hidden;
        }
        .review-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: flex-start;
            padding: 1rem 1.1rem;
            background: #FFFFFF;
            border-bottom: 1px solid var(--border-light);
        }
        .review-title {
            margin-top: 0.2rem;
            font-size: 1.2rem;
            line-height: 1.25;
            color: var(--text);
        }
        .review-subhead {
            margin-top: 0.25rem;
            color: var(--text-secondary);
            font-size: 0.78rem;
        }
        .review-summary-strip {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.7rem 1.1rem;
            background: #FFFFFF;
            border-bottom: 1px solid var(--border-light);
        }
        .review-summary-line {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            min-width: 0;
        }
        .review-summary-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            min-height: 28px;
            padding: 0.32rem 0.52rem;
            border: 1px solid var(--border-light);
            border-radius: 999px;
            background: #F8FAFD;
            color: var(--text-secondary);
            font-size: 0.72rem;
            line-height: 1.1;
            white-space: nowrap;
        }
        .review-summary-chip strong {
            color: var(--text);
            font-weight: 800;
        }
        .review-summary-chip.risk {
            background: var(--critical-bg);
            color: var(--critical);
            border-color: var(--critical-border);
        }
        .review-summary-chip.expected {
            background: var(--success-bg);
            color: var(--success);
            border-color: rgba(22,163,74,0.25);
        }
        .review-summary-chip.coverage {
            background: var(--teal-light);
            color: var(--teal);
            border-color: rgba(0,145,160,0.24);
        }
        .review-summary-chip.a-side {
            background: #EAF1FF;
            color: var(--kpmg-blue);
            border-color: #C9D7F2;
        }
        .review-summary-chip.h-side {
            background: var(--teal-light);
            color: var(--teal);
            border-color: rgba(0,145,160,0.24);
        }
        .review-actions {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .review-close,
        .review-secondary {
            border: 1px solid var(--border);
            background: #FFFFFF;
            color: var(--text-secondary);
            border-radius: 7px;
            padding: 0.48rem 0.7rem;
            font-size: 0.78rem;
            font-weight: 700;
            cursor: pointer;
        }
        .review-close {
            color: var(--text);
        }
        .review-close:hover,
        .review-secondary:hover {
            background: var(--accent-light);
            color: var(--kpmg-blue);
            border-color: #C9D7F2;
        }
        .review-grid {
            min-height: 0;
            display: grid;
            grid-template-columns: minmax(260px, 0.75fr) minmax(420px, 1.35fr) minmax(270px, 0.8fr);
            gap: 0.85rem;
            padding: 0.85rem;
        }
        .review-panel {
            min-height: 0;
            overflow: auto;
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
        }
        .review-panel-head {
            position: sticky;
            top: 0;
            z-index: 5;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.6rem;
            padding: 0.75rem 0.85rem;
            background: #FFFFFF;
            border-bottom: 1px solid var(--border-light);
            color: var(--text);
            font-size: 0.82rem;
            font-weight: 800;
        }
        .review-panel-count {
            color: var(--text-tertiary);
            font-size: 0.68rem;
            font-weight: 700;
            white-space: nowrap;
        }
        .review-chain,
        .review-focus,
        .review-meta {
            padding: 0.85rem;
        }
        .review-evidence-card {
            display: block;
            width: 100%;
            appearance: none;
            font: inherit;
            text-align: left;
            border: 1px solid var(--border-light);
            border-left: 3px solid var(--kpmg-blue);
            border-radius: 8px;
            padding: 0.75rem;
            background: #FBFCFE;
            margin-bottom: 0.65rem;
            color: inherit;
            cursor: pointer;
            transition: border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
        }
        .review-evidence-card:hover {
            border-color: #C9D7F2;
            background: #F5F8FF;
        }
        .review-evidence-card.active {
            border-color: #B8C9EE;
            background: #EEF4FF;
            box-shadow: inset 0 0 0 1px rgba(30,64,175,0.12);
        }
        .review-evidence-card.h-side {
            border-left-color: var(--teal);
        }
        .review-evidence-card.h-side.active {
            background: #EEFDFE;
            border-color: rgba(0,145,160,0.28);
            box-shadow: inset 0 0 0 1px rgba(0,145,160,0.12);
        }
        .review-evidence-card:focus-visible {
            outline: 2px solid var(--kpmg-blue);
            outline-offset: 2px;
        }
        .review-evidence-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.6rem;
            margin-bottom: 0.45rem;
            color: var(--text-secondary);
            font-size: 0.72rem;
            font-weight: 700;
        }
        .review-evidence-meta {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            min-width: 0;
        }
        .review-evidence-index {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 1.3rem;
            height: 1.3rem;
            border-radius: 999px;
            background: #E8EEF8;
            color: var(--kpmg-blue);
            font-size: 0.65rem;
            font-weight: 800;
        }
        .review-evidence-card.h-side .review-evidence-index {
            background: var(--teal-light);
            color: var(--teal);
        }
        .review-snippet {
            color: var(--text);
            font-size: 0.82rem;
            line-height: 1.55;
            word-break: break-word;
        }
        .review-evidence-card .review-snippet {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .review-bbox {
            margin-top: 0.45rem;
            font-family: Consolas, 'Courier New', monospace;
            color: var(--text-tertiary);
            font-size: 0.68rem;
        }
        .review-summary-card {
            padding: 1rem;
            background: #F8FAFD;
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            margin-bottom: 0.85rem;
        }
        .review-summary-card p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.65;
        }
        .review-explanation-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.7rem;
            margin-top: 0.75rem;
        }
        .review-explanation-card {
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.75rem;
            background: #FFFFFF;
            border-top: 3px solid var(--kpmg-blue);
        }
        .review-explanation-card.h-side {
            border-top-color: var(--teal);
        }
        .review-explanation-label {
            color: var(--text-tertiary);
            font-size: 0.7rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
        }
        .review-explanation-value {
            color: var(--text);
            font-size: 0.9rem;
            font-weight: 750;
            line-height: 1.4;
            word-break: break-word;
        }
        .review-explanation-snippet {
            margin-top: 0.45rem;
            color: var(--text-secondary);
            font-size: 0.78rem;
            line-height: 1.55;
            word-break: break-word;
        }
        .review-current-card {
            margin-bottom: 0.85rem;
            padding: 0.95rem;
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            border-left: 4px solid var(--kpmg-blue);
            border-radius: var(--radius);
        }
        .review-current-card.h-side {
            border-left-color: var(--teal);
        }
        .review-current-card.risk {
            border-left-color: var(--critical);
            background: linear-gradient(90deg, rgba(185,28,28,0.05), #FFFFFF 38%);
        }
        .review-current-card.expected {
            border-left-color: var(--success);
            background: linear-gradient(90deg, rgba(22,163,74,0.06), #FFFFFF 38%);
        }
        .review-current-card.coverage {
            border-left-color: var(--teal);
            background: linear-gradient(90deg, rgba(0,145,160,0.06), #FFFFFF 38%);
        }
        .review-current-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 0.65rem;
        }
        .review-current-title {
            color: var(--text);
            font-size: 0.86rem;
            font-weight: 800;
        }
        .review-current-empty {
            margin-top: 0.18rem;
            color: var(--text-secondary);
            font-size: 0.74rem;
            line-height: 1.5;
        }
        .review-current-meta {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 0.35rem;
        }
        .review-current-snippet {
            color: var(--text);
            font-size: 0.96rem;
            line-height: 1.75;
            word-break: break-word;
            padding: 0.8rem;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            background: #F8FAFD;
        }
        .review-current-bbox {
            margin-top: 0.55rem;
            color: var(--text-tertiary);
            font-family: Consolas, 'Courier New', monospace;
            font-size: 0.7rem;
            word-break: break-word;
        }
        .review-compare {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 0.85rem;
        }
        .review-value-card {
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            padding: 0.85rem;
            background: #FFFFFF;
        }
        .review-value-card.a-side { border-top: 3px solid var(--kpmg-blue); }
        .review-value-card.h-side { border-top: 3px solid var(--teal); }
        .review-value-label {
            color: var(--text-tertiary);
            font-size: 0.72rem;
            font-weight: 800;
            margin-bottom: 0.35rem;
        }
        .review-value-main {
            color: var(--text);
            font-size: 1.28rem;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
        }
        .review-value-sub {
            margin-top: 0.25rem;
            color: var(--text-tertiary);
            font-size: 0.74rem;
        }
        .review-meta-grid {
            display: grid;
            gap: 0.55rem;
        }
        .review-meta-item {
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 0.65rem;
            background: #FBFCFE;
        }
        .review-meta-label {
            color: var(--text-tertiary);
            font-size: 0.68rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }
        .review-meta-value {
            color: var(--text);
            font-size: 0.82rem;
            line-height: 1.45;
            word-break: break-word;
        }
        .review-badges {
            display: flex;
            gap: 0.35rem;
            flex-wrap: wrap;
        }
        @media (max-width: 1280px) {
            .dashboard.active {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
            .audit-strip.active {
                grid-template-columns: 1fr;
            }
            .audit-status {
                justify-content: flex-start;
                min-width: 0;
            }
            .review-grid {
                grid-template-columns: minmax(230px, 0.7fr) minmax(360px, 1.2fr);
            }
            .review-grid .review-panel.meta-panel {
                grid-column: 1 / -1;
            }
        }
        @media (max-width: 1024px) {
            .launch-panel {
                grid-template-columns: 1fr;
            }
            .launch-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
            .view-tabs {
                top: 0;
            }
            .review-grid {
                grid-template-columns: 1fr;
                overflow: auto;
            }
            .review-panel {
                min-height: 220px;
            }
        }
        @media (max-width: 768px) {
            .launch-grid {
                grid-template-columns: 1fr;
            }
            .dashboard.active,
            .dashboard {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
            .review-overlay {
                padding: 0;
            }
            .review-shell {
                height: 100vh;
                border-radius: 0;
            }
            .review-header,
            .review-compare {
                grid-template-columns: 1fr;
            }
            .review-header {
                flex-direction: column;
            }
            .review-actions {
                justify-content: flex-start;
            }
            .review-summary-strip,
            .review-current-head {
                align-items: flex-start;
                flex-direction: column;
            }
            .review-current-meta {
                justify-content: flex-start;
            }
        }
        @media (max-width: 1024px) {
            .workspace-layout {
                grid-template-columns: 1fr;
            }
            .control-rail {
                position: static;
                max-height: none;
            }
            .control-rail .history-list {
                flex: 0 0 auto;
                max-height: 320px;
            }
        }
    </style>
</head>
<body>
    <div class="slogan-bar" style="background:var(--kpmg-blue);color:#fff;text-align:center;padding:10px 1rem 8px;letter-spacing:0.04em;font-family:var(--font-serif),'Microsoft YaHei',sans-serif;">
        <span style="font-size:1.1rem;font-weight:700;">双重披露 · 一次核对</span>
        <span style="font-size:0.7rem;font-weight:500;opacity:0.72;margin-left:0.85rem;letter-spacing:0.06em;text-transform:uppercase;">Two Filings. One Source of Truth.</span>
    </div>
    <header class="header">
        <div class="header-inner">
            <div class="brand">
                <div>
                    <span class="brand-title">KPMG Hackathon</span>
                    <span class="brand-sub">A+H Consistency Checker</span>
                </div>
            </div>
            <div class="status-badge" id="statusBadge">
                    <span class="dot"></span>
                    <span id="statusText">就绪</span>
                </div>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="workspace-layout">
            <aside class="control-rail" aria-label="核查操作">
        <!-- Upload -->
        <div class="upload-card">
            <h2 class="upload-heading">上传年报</h2>
            <p class="upload-desc" id="uploadDesc">分别上传 A 股和 H 股年度报告 PDF，系统将自动解析、画像并核查数据一致性。</p>
            <div class="mode-field">
                <label class="mode-label">核查类型</label>
                <div class="mode-control" role="radiogroup" aria-label="核查类型">
                    <label class="mode-option">
                        <input type="radio" name="checkMode" value="ah" checked onchange="applyCheckMode()">
                        <span>A+H 股报告检查</span>
                    </label>
                    <label class="mode-option">
                        <input type="radio" name="checkMode" value="h_bilingual" onchange="applyCheckMode()">
                        <span>H 股中英文报告检查</span>
                    </label>
                </div>
            </div>
            <div class="company-field">
                <label for="companyName">公司名称 / 简称</label>
                <input id="companyName" type="text" maxlength="80" autocomplete="organization" oninput="checkReady()">
                <div class="company-helper">用于标识核查历史，不改变报告文件名。</div>
            </div>
            <div class="upload-grid">
                <div class="dropzone" id="uploadA">
                    <input type="file" id="fileA" accept=".pdf" onchange="onFileSelected('A', this)">
                    <div class="dz-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                    </div>
                    <div class="dz-title" id="uploadTitleA">A 股年报</div>
                    <div class="dz-hint" id="uploadHintA">点击或拖拽上传 PDF</div>
                    <div class="dz-file" id="filenameA"></div>
                </div>
                <div class="dropzone" id="uploadH">
                    <input type="file" id="fileH" accept=".pdf" onchange="onFileSelected('H', this)">
                    <div class="dz-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                    </div>
                    <div class="dz-title" id="uploadTitleH">H 股年报</div>
                    <div class="dz-hint" id="uploadHintH">点击或拖拽上传 PDF</div>
                    <div class="dz-file" id="filenameH"></div>
                </div>
            </div>
            <div style="text-align: center;">
                <button class="btn-primary" id="startBtn" onclick="startCheck()" aria-disabled="true">
                    <span id="btnText">启动核查</span>
                </button>
            </div>
        </div>

        <!-- History -->
        <div class="history-card" id="historySection">
            <div class="history-header">
                <span class="history-title">核查历史</span>
                <span class="history-count" id="historyCount"></span>
            </div>
            <div class="history-list" id="historyList"></div>
        </div>

            </aside>

            <section class="work-area" aria-label="核查结果">
        <div class="launch-panel" id="launchPanel">
            <div>
                <div class="launch-head">
                    <div>
                        <div class="launch-eyebrow">Audit Workbench</div>
                        <h1 class="launch-title" id="launchTitle">A/H 年报核查台</h1>
                        <p class="launch-copy" id="launchCopy">上传两份年报后，系统会自动完成全量扫描、画像、差异分流和证据定位。</p>
                    </div>
                    <div class="launch-status">等待上传</div>
                </div>
                <div class="launch-grid">
                    <div class="launch-step">
                        <span>01</span>
                        <strong>全量扫描</strong>
                        <small>整份报告逐页抽取，不按页数截断。</small>
                    </div>
                    <div class="launch-step">
                        <span>02</span>
                        <strong id="launchStep2Title">A/H 画像</strong>
                        <small id="launchStep2Copy">指标、叙述、章节树同步沉淀。</small>
                    </div>
                    <div class="launch-step">
                        <span>03</span>
                        <strong>证据审阅</strong>
                        <small>点击差异、覆盖项或预警项直接审阅证据。</small>
                    </div>
                </div>
            </div>
        </div>
        <!-- Progress -->
        <div class="progress-card" id="progressSection">
            <div class="progress-track">
                <div class="progress-fill" id="progressBar"></div>
            </div>
            <div class="stages" id="progressStages">
                <div class="stage" data-stage="pending">待开始</div>
                <div class="stage" data-stage="parsing">解析</div>
                <div class="stage" data-stage="profiling" id="stageProfiling">画像</div>
                <div class="stage" data-stage="checking">检查</div>
                <div class="stage" data-stage="reporting">报告</div>
            </div>
            <div class="progress-msg" id="progressMessage">准备中...</div>
        </div>

        <div class="warning-panel" id="warningPanel" aria-live="polite"></div>

        <div class="audit-strip" id="auditStrip" aria-live="polite"></div>

        <!-- Dashboard -->
        <div class="dashboard" id="dashboard">
        </div>

        <!-- Results -->
        <div class="results-wrap" id="resultsSection">
            <div class="view-tabs" id="resultViewTabs" style="display:none;">
                <button class="view-tab active" id="tabProfileA" data-view="profile-a" data-ah-only="true" onclick="setResultView('profile-a')"><span id="tabProfileAText">A 画像</span> <span class="tab-count" id="tabCountProfileA">0</span></button>
                <button class="view-tab" id="tabProfileH" data-view="profile-h" data-ah-only="true" onclick="setResultView('profile-h')"><span id="tabProfileHText">H 画像</span> <span class="tab-count" id="tabCountProfileH">0</span></button>
                <button class="view-tab" data-view="real-diff" onclick="setResultView('real-diff')"><span id="tabRealDiffText">真实差异</span> <span class="tab-count" id="tabCountRealDiff">0</span></button>
                <button class="view-tab" data-view="expected-diff" onclick="setResultView('expected-diff')">预期差异 <span class="tab-count" id="tabCountExpectedDiff">0</span></button>
                <button class="view-tab" data-view="coverage" onclick="setResultView('coverage')"><span id="tabCoverageText">披露覆盖</span> <span class="tab-count" id="tabCountCoverage">0</span></button>
                <button class="view-tab" data-view="evidence" onclick="setResultView('evidence')">证据定位 <span class="tab-count" id="tabCountEvidence">0</span></button>
            </div>

            <div class="view-pane active" id="view-profile-a" data-ah-only="true">
                <div class="profile-grid" id="profileSummaryA"></div>
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">数值画像</div>
                        <div class="profile-section-count" id="profileACount"></div>
                    </div>
                    <div class="profile-scroll">
                        <table class="profile-table">
                            <thead>
                                <tr>
                                    <th>Key</th>
                                    <th>名称</th>
                                    <th>值</th>
                                    <th>单位/币种</th>
                                    <th>页码</th>
                                    <th>出现</th>
                                    <th>一致性</th>
                                    <th>全量</th>
                                </tr>
                            </thead>
                            <tbody id="profileAMetricBody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">文字画像</div>
                        <div class="profile-section-count" id="profileANarrativeCount"></div>
                    </div>
                    <div class="profile-scroll">
                        <table class="profile-table">
                            <thead>
                                <tr>
                                    <th>主题</th>
                                    <th>Topic Key</th>
                                    <th>页码范围</th>
                                    <th>字数</th>
                                    <th>层级</th>
                                    <th>摘要</th>
                                    <th>全量段落</th>
                                </tr>
                            </thead>
                            <tbody id="profileANarrativeBody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">结构树</div>
                        <div class="profile-section-count" id="profileAStructureCount"></div>
                    </div>
                    <div class="structure-tree" id="profileAStructure"></div>
                </div>
            </div>

            <div class="view-pane" id="view-profile-h" data-ah-only="true">
                <div class="profile-grid" id="profileSummaryH"></div>
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">数值画像</div>
                        <div class="profile-section-count" id="profileHCount"></div>
                    </div>
                    <div class="profile-scroll">
                        <table class="profile-table">
                            <thead>
                                <tr>
                                    <th>Key</th>
                                    <th>名称</th>
                                    <th>值</th>
                                    <th>单位/币种</th>
                                    <th>页码</th>
                                    <th>出现</th>
                                    <th>一致性</th>
                                    <th>全量</th>
                                </tr>
                            </thead>
                            <tbody id="profileHMetricBody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">文字画像</div>
                        <div class="profile-section-count" id="profileHNarrativeCount"></div>
                    </div>
                    <div class="profile-scroll">
                        <table class="profile-table">
                            <thead>
                                <tr>
                                    <th>主题</th>
                                    <th>Topic Key</th>
                                    <th>页码范围</th>
                                    <th>字数</th>
                                    <th>层级</th>
                                    <th>摘要</th>
                                    <th>全量段落</th>
                                </tr>
                            </thead>
                            <tbody id="profileHNarrativeBody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">结构树</div>
                        <div class="profile-section-count" id="profileHStructureCount"></div>
                    </div>
                    <div class="structure-tree" id="profileHStructure"></div>
                </div>
            </div>

            <div class="view-pane" id="view-diffs">
                <div class="filter-bar">
                    <div class="filter-group">
                        <label>类型</label>
                        <div id="typeFilters">
                            <span class="chip active" data-type="all" onclick="toggleFilter('type', 'all')">全部</span>
                            <span class="chip" data-type="numeric" onclick="toggleFilter('type', 'numeric')">数值</span>
                            <span class="chip" data-type="standard" onclick="toggleFilter('type', 'standard')">准则</span>
                            <span class="chip" data-type="disclosure" onclick="toggleFilter('type', 'disclosure')">披露</span>
                            <span class="chip" data-type="chart" onclick="toggleFilter('type', 'chart')">图表</span>
                            <span class="chip" data-type="internal" onclick="toggleFilter('type', 'internal')">内部</span>
                        </div>
                    </div>
                    <div class="filter-group">
                        <label>严重度</label>
                        <div id="sevFilters">
                            <span class="chip active" data-sev="all" onclick="toggleFilter('sev', 'all')">全部</span>
                            <span class="chip" data-sev="critical" onclick="toggleFilter('sev', 'critical')">Critical</span>
                            <span class="chip" data-sev="high" onclick="toggleFilter('sev', 'high')">High</span>
                            <span class="chip" data-sev="medium" onclick="toggleFilter('sev', 'medium')">Medium</span>
                            <span class="chip" data-sev="low" onclick="toggleFilter('sev', 'low')">Low</span>
                            <span class="chip" data-sev="info" onclick="toggleFilter('sev', 'info')">Info</span>
                        </div>
                    </div>
                </div>

                <div class="table-card">
                    <div class="table-scroll">
                        <table class="diff-table" id="diffTable">
                            <thead>
                                <tr>
                                    <th class="col-narrow">#</th>
                                    <th class="col-triage">分流</th>
                                    <th class="col-sev">严重度</th>
                                    <th class="col-type">类型</th>
                                    <th class="col-explanation">差异说明</th>
                                    <th class="col-topic">主题</th>
                                    <th class="col-num" id="diffAValueHeader">A 股值</th>
                                    <th class="col-num" id="diffHValueHeader">H 股值</th>
                                    <th class="col-pages">页码</th>
                                    <th class="col-action">审阅</th>
                                </tr>
                            </thead>
                            <tbody id="diffTableBody"></tbody>
                        </table>
                    </div>
                    <div class="empty-state" id="emptyState" style="display:none;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <p>当前筛选条件下无差异</p>
                    </div>
                </div>

                <!-- Detail -->
                <div class="detail-card" id="detailPanel">
                    <div class="detail-header">
                        <div class="detail-title-wrap">
                            <h3 id="detailTitle">差异详情</h3>
                            <div class="meta" id="detailMeta"></div>
                        </div>
                        <div class="detail-badges" id="detailBadges"></div>
                    </div>
                    <div class="detail-body">
                        <div class="detail-main">
                            <div class="section-label">差异说明</div>
                            <p class="desc-text" id="detailSummary"></p>

                            <div class="section-label">数值对比</div>
                            <div class="compare-row">
                                <div class="compare-box a-side">
                                    <div class="side-label" id="detailALabel">A 股</div>
                                    <div class="side-value" id="detailAValue">&mdash;</div>
                                    <div class="side-delta" id="detailADelta"></div>
                                </div>
                                <div class="compare-box h-side">
                                    <div class="side-label" id="detailHLabel">H 股</div>
                                    <div class="side-value" id="detailHValue">&mdash;</div>
                                    <div class="side-delta" id="detailHDelta"></div>
                                </div>
                            </div>

                            <div id="reasoningSection" style="display:none;">
                                <div class="section-label">AI 准则解读</div>
                                <div class="reasoning-card" id="reasoningBox"></div>
                            </div>

                            <div id="chartCrossSection" style="display:none;">
                                <div class="section-label">图表三方核对</div>
                                <div id="chartCrossContent"></div>
                            </div>
                        </div>
                        <div class="detail-side">
                            <div class="section-label">证据链</div>
                            <div class="evidence-list" id="evidenceList"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="view-pane" id="view-coverage">
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">披露覆盖 / 未匹配项</div>
                        <div class="profile-section-count" id="coverageCount"></div>
                    </div>
                    <div class="table-card">
                        <div class="table-scroll">
                            <table class="diff-table evidence-table" id="coverageTable">
                                <thead>
                                    <tr>
                                        <th class="col-narrow">#</th>
                                        <th class="col-triage">状态</th>
                                    <th class="col-type">类别</th>
                                    <th class="col-topic">主题</th>
                                    <th id="coverageAEvidenceHeader"> A 证据</th>
                                    <th id="coverageHEvidenceHeader"> H 证据</th>
                                    <th class="col-pages">置信度</th>
                                    <th class="col-topic">说明</th>
                                    <th class="col-action">审阅</th>
                                </tr>
                            </thead>
                                <tbody id="coverageTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="view-pane" id="view-evidence">
                <div class="profile-section">
                    <div class="profile-section-header">
                        <div class="profile-section-title">证据定位</div>
                        <div class="profile-section-count" id="evidenceCount"></div>
                    </div>
                    <div class="table-card">
                        <div class="table-scroll">
                            <table class="diff-table evidence-table" id="evidenceTable">
                                <thead>
                                    <tr>
                                        <th class="col-narrow">#</th>
                                        <th class="col-triage">分流</th>
                                        <th class="col-type">类型</th>
                                        <th class="col-topic">主题</th>
                                        <th id="evidenceAEvidenceHeader"> A 证据</th>
                                        <th id="evidenceHEvidenceHeader"> H 证据</th>
                                        <th class="col-pages">页码</th>
                                    </tr>
                                </thead>
                                <tbody id="evidenceTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="download-bar" id="downloadBar">
                <a class="btn-dl" id="downloadXlsx" href="#" target="_blank">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Excel 报告
                </a>
                <a class="btn-dl" id="downloadPdf" href="#" target="_blank">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    PDF 报告
                </a>
            </div>
        </div>
            </section>
        </div>
    </main>

    <div class="review-overlay" id="reviewOverlay" aria-hidden="true" onclick="if (event.target === this) closeEvidenceReview()">
        <div class="review-shell" role="dialog" aria-modal="true" aria-labelledby="reviewTitle">
            <div class="review-header">
                <div>
                    <div class="review-eyebrow" id="reviewEyebrow">证据审阅</div>
                    <div class="review-title" id="reviewTitle">-</div>
                    <div class="review-subhead" id="reviewSubhead">-</div>
                </div>
                <div class="review-actions">
                    <button class="review-secondary" type="button" id="reviewSourceBtn" onclick="focusReviewSource()">定位列表</button>
                    <button class="review-close" type="button" onclick="closeEvidenceReview()">关闭</button>
                </div>
            </div>
            <div class="review-summary-strip">
                <div class="review-summary-line" id="reviewSummaryStrip"></div>
                <div class="review-badges" id="reviewBadges"></div>
            </div>
            <div class="review-grid">
                <aside class="review-panel">
                    <div class="review-panel-head"><span>证据链</span><span class="review-panel-count" id="reviewChainCount">A 0 / H 0</span></div>
                    <div class="review-chain" id="reviewEvidenceList"></div>
                </aside>
                <section class="review-panel">
                    <div class="review-panel-head">对照视图</div>
                    <div class="review-focus">
                        <div id="reviewCurrentEvidence"></div>
                        <div class="review-summary-card">
                            <div class="review-eyebrow" id="reviewTypeLabel">差异</div>
                            <p id="reviewSummary">-</p>
                            <div id="reviewExplanationItems"></div>
                        </div>
                        <div class="review-compare">
                            <div class="review-value-card a-side">
                                <div class="review-value-label" id="reviewALabel">A 股</div>
                                <div class="review-value-main" id="reviewAValue">—</div>
                                <div class="review-value-sub" id="reviewADelta"></div>
                            </div>
                            <div class="review-value-card h-side">
                                <div class="review-value-label" id="reviewHLabel">H 股</div>
                                <div class="review-value-main" id="reviewHValue">—</div>
                                <div class="review-value-sub" id="reviewHDelta"></div>
                            </div>
                        </div>
                        <div id="reviewReasoningWrap" style="display:none; margin-bottom:0.85rem;">
                            <div class="review-summary-card">
                                <div class="review-eyebrow">规则解读</div>
                                <div id="reviewReasoning"></div>
                            </div>
                        </div>
                        <div id="reviewChartWrap" style="display:none;">
                            <div class="review-summary-card">
                                <div class="review-eyebrow">图表校核</div>
                                <div id="reviewChart"></div>
                            </div>
                        </div>
                    </div>
                </section>
                <aside class="review-panel meta-panel">
                    <div class="review-panel-head">元数据</div>
                    <div class="review-meta">
                        <div class="review-meta-grid" id="reviewMetaGrid"></div>
                    </div>
                </aside>
            </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
        let files = { A: null, H: null };
        let currentJob = null;
        let allDiffs = [];
        let allCoverage = [];
        let activeFilters = { type: 'all', sev: 'all' };
        let activeTriage = 'real';
        let selectedDiffId = null;
        let activeView = 'profile-a';
        let activeReviewSourceView = 'diffs';
        let activeReviewKind = 'diff';
        let activeReviewItem = null;
        let activeReviewEvidenceIndex = 0;

        const API_BASE = window.location.protocol === 'file:' ? 'http://127.0.0.1:8000' : '';

        const ICONS = {
            file: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',
            check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
            alert: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
            page: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>'
        };

        function getCheckMode() {
            return document.querySelector('input[name="checkMode"]:checked')?.value || 'ah';
        }

        function labelsForMode(mode) {
            if (mode === 'h_bilingual') {
                return {
                    mode: 'h_bilingual',
                    desc: '分别上传 H 股中文报告和 H 股英文报告 PDF，系统以中文报告为准核对英文翻译、数字和单位。',
                    A: 'H中文',
                    H: 'H英文',
                    aTag: 'H中',
                    hTag: 'H英',
                    aUpload: 'H股中文报告',
                    hUpload: 'H股英文报告',
                    aFact: '中文事实',
                    hFact: '英文事实',
                    aValueHeader: '中文取值',
                    hValueHeader: '英文取值',
                    aEvidenceHeader: '中文证据',
                    hEvidenceHeader: '英文证据',
                    realDiffTab: '英文翻译问题',
                    coverageTab: '章节排版',
                    launchTitle: 'H 股中英文报告核查台',
                    launchCopy: '上传 H 股中文和英文报告，系统以中文为准核对英文翻译、数字、金额、单位及比例。',
                    launchStep2Title: '中→英配对',
                    launchStep2Copy: '以中文为准，定位英文报告对应段落与表格。',
                    stageProfiling: '配对',
                };
            }
            return {
                mode: 'ah',
                desc: '分别上传 A 股和 H 股年度报告 PDF，系统将自动解析、画像并核查数据一致性。',
                A: 'A',
                H: 'H',
                aTag: 'A',
                hTag: 'H',
                aUpload: 'A 股年报',
                hUpload: 'H 股年报',
                aFact: 'A 事实',
                hFact: 'H 事实',
                aValueHeader: 'A 股值',
                hValueHeader: 'H 股值',
                aEvidenceHeader: 'A 证据',
                hEvidenceHeader: 'H 证据',
                profileATab: 'A 画像',
                profileHTab: 'H 画像',
                realDiffTab: '真实差异',
                coverageTab: '披露覆盖',
                launchTitle: 'A/H 年报核查台',
                launchCopy: '上传两份年报后，系统会自动完成全量扫描、画像、差异分流和证据定位。',
                launchStep2Title: 'A/H 画像',
                launchStep2Copy: '指标、叙述、章节树同步沉淀。',
                stageProfiling: '画像',
            };
        }

        function isBilingualJob(job) {
            const summary = job?.comparison_summary || {};
            return (job?.check_mode || job?.checkMode || summary.check_mode || 'ah') === 'h_bilingual';
        }

        function sideLabelsForJob(job) {
            const summary = job?.comparison_summary || {};
            const mode = job?.check_mode || job?.checkMode || summary.check_mode || 'ah';
            const labels = labelsForMode(mode);
            const sideLabels = summary.side_labels || {};
            return {
                ...labels,
                A: sideLabels.A || labels.A,
                H: sideLabels.H || labels.H,
            };
        }

        function defaultResultViewForJob(job) {
            return isBilingualJob(job) ? 'real-diff' : 'profile-a';
        }

        function setTextIfExists(id, value) {
            const el = document.getElementById(id);
            if (el) el.textContent = value;
        }

        function configureResultMode(job) {
            const labels = sideLabelsForJob(job);
            const bilingual = isBilingualJob(job);
            document.querySelectorAll('[data-ah-only="true"]').forEach((el) => {
                el.style.display = bilingual ? 'none' : '';
            });
            if (!bilingual) {
                setTextIfExists('tabProfileAText', labels.profileATab);
                setTextIfExists('tabProfileHText', labels.profileHTab);
            }
            setTextIfExists('tabRealDiffText', labels.realDiffTab);
            setTextIfExists('tabCoverageText', labels.coverageTab);
            setTextIfExists('diffAValueHeader', labels.aValueHeader);
            setTextIfExists('diffHValueHeader', labels.hValueHeader);
            setTextIfExists('coverageAEvidenceHeader', labels.aEvidenceHeader);
            setTextIfExists('coverageHEvidenceHeader', labels.hEvidenceHeader);
            setTextIfExists('evidenceAEvidenceHeader', labels.aEvidenceHeader);
            setTextIfExists('evidenceHEvidenceHeader', labels.hEvidenceHeader);
            setTextIfExists('detailALabel', labels.A);
            setTextIfExists('detailHLabel', labels.H);
            setTextIfExists('reviewALabel', labels.A);
            setTextIfExists('reviewHLabel', labels.H);
        }

        function applyCheckMode() {
            const labels = labelsForMode(getCheckMode());
            const desc = document.getElementById('uploadDesc');
            const titleA = document.getElementById('uploadTitleA');
            const titleH = document.getElementById('uploadTitleH');
            const hintA = document.getElementById('uploadHintA');
            const hintH = document.getElementById('uploadHintH');
            if (desc) desc.textContent = labels.desc;
            if (titleA) titleA.textContent = labels.aUpload;
            if (titleH) titleH.textContent = labels.hUpload;
            if (hintA) hintA.textContent = '点击或拖拽上传 PDF';
            if (hintH) hintH.textContent = '点击或拖拽上传 PDF';
            setTextIfExists('launchTitle', labels.launchTitle);
            setTextIfExists('launchCopy', labels.launchCopy);
            setTextIfExists('launchStep2Title', labels.launchStep2Title);
            setTextIfExists('launchStep2Copy', labels.launchStep2Copy);
            setTextIfExists('stageProfiling', labels.stageProfiling);
            checkReady();
        }

        function onFileSelected(side, input) {
            const file = input.files[0];
            if (!file) return;
            files[side] = file;
            const fn = document.getElementById('filename' + side);
            fn.innerHTML = ICONS.file + '<span>' + escapeHtml(file.name) + '</span>';
            document.getElementById('upload' + side).classList.add('has-file');
            checkReady();
        }

        function getCompanyName() {
            return (document.getElementById('companyName')?.value || '').trim();
        }

        function getUploadValidationTargets() {
            const labels = labelsForMode(getCheckMode());
            return [
                { key: 'company', label: '公司名称', element: document.querySelector('.company-field') },
                { key: 'A', label: labels.aUpload, element: document.getElementById('uploadA') },
                { key: 'H', label: labels.hUpload, element: document.getElementById('uploadH') }
            ];
        }

        function shakeField(element) {
            if (!element) return;
            element.classList.remove('shake');
            void element.offsetWidth;
            element.classList.add('shake');
            setTimeout(() => element.classList.remove('shake'), 420);
        }

        function markMissingUploadFields(missing, notify) {
            const missingKeys = new Set(missing.map(item => item.key));
            getUploadValidationTargets().forEach(target => {
                if (!target.element) return;
                const isMissing = missingKeys.has(target.key);
                if (isMissing && notify) {
                    target.element.classList.add('field-missing');
                    shakeField(target.element);
                } else if (!isMissing) {
                    target.element.classList.remove('field-missing', 'shake');
                }
            });
        }

        function validateUploadInputs({ notify = false } = {}) {
            const companyName = getCompanyName();
            const labels = labelsForMode(getCheckMode());
            const missing = [];
            if (!companyName) missing.push({ key: 'company', label: '公司名称' });
            if (!files.A) missing.push({ key: 'A', label: labels.aUpload });
            if (!files.H) missing.push({ key: 'H', label: labels.hUpload });

            markMissingUploadFields(missing, notify);
            if (notify && missing.length) {
                if (missing.some(item => item.key === 'company')) {
                    document.getElementById('companyName')?.focus();
                }
                showToast('请补齐：' + missing.map(item => item.label).join('、'), 'error');
            }
            return { ok: missing.length === 0, companyName, missing };
        }

        function checkReady() {
            const state = validateUploadInputs();
            const btn = document.getElementById('startBtn');
            if (btn && !btn.disabled) {
                btn.setAttribute('aria-disabled', state.ok ? 'false' : 'true');
            }
            return state.ok;
        }

        function escapeHtml(s) {
            const d = document.createElement('div');
            d.textContent = s;
            return d.innerHTML;
        }

        function showToast(msg, type) {
            const toast = document.getElementById('toast');
            const icon = type === 'success' ? ICONS.check : ICONS.alert;
            toast.innerHTML = icon + '<span>' + escapeHtml(msg) + '</span>';
            toast.className = 'toast ' + type;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 4000);
        }

        function setStatus(text, cls) {
            const badge = document.getElementById('statusBadge');
            document.getElementById('statusText').textContent = text;
            badge.className = 'status-badge ' + (cls || '');
        }

        function normalizeStage(stage) {
            return stage || 'pending';
        }

        function normalizeProgressMessage(message) {
            return message || '';
        }

        function updateProgress(percent, message, status) {
            const normalizedStatus = normalizeStage(status);
            const normalizedMessage = normalizeProgressMessage(message);
            document.getElementById('progressBar').style.width = percent + '%';
            document.getElementById('progressMessage').textContent = normalizedMessage;
            const stages = document.querySelectorAll('.stage');
            const map = { pending: 0, parsing: 1, profiling: 2, checking: 3, reporting: 4, done: 4 };
            const idx = map[normalizedStatus] ?? -1;
            stages.forEach((s, i) => {
                s.classList.remove('active', 'completed', 'error');
                if (i < idx) s.classList.add('completed');
                else if (i === idx) s.classList.add('active');
            });
        }

        function normalizeJob(job) {
            const progress = safeArray(job.progress).map((item) => {
                const stage = normalizeStage(item.stage);
                return {
                    ...item,
                    stage,
                    message: normalizeProgressMessage(item.message, item.stage),
                };
            });
            return {
                ...job,
                status: normalizeStage(job.status),
                company_name: job.company_name || job.companyName || null,
                check_mode: job.check_mode || job.checkMode || job.comparison_summary?.check_mode || 'ah',
                progress,
                profile_a: job.profile_a || job.profileA || null,
                profile_h: job.profile_h || job.profileH || null,
                comparison_summary: job.comparison_summary || job.comparisonSummary || {},
                diffs: job.diffs || [],
                coverage_items: job.coverage_items || job.coverageItems || [],
            };
        }

        function triageLabel(value) {
            const map = { real: '真实', expected: '预期', unresolved: '待判' };
            return map[value] || value || '真实';
        }

        function triageClass(value) {
            const map = { real: 'badge-real', expected: 'badge-expected', unresolved: 'badge-unresolved' };
            return map[value] || 'badge-unresolved';
        }

        function coverageStatusLabel(value) {
            const map = { matched: '已匹配', a_only: '仅 A 披露', h_only: '仅 H 披露' };
            return map[value] || value || '—';
        }

        function coverageStatusClass(value) {
            const map = { matched: 'badge-expected', a_only: 'badge-unresolved', h_only: 'badge-unresolved' };
            return map[value] || 'badge-unresolved';
        }

        function countsForProfile(profile) {
            return {
                metric_keys: profile?.metric_keys || 0,
                metric_occurrences: profile?.metric_occurrences || 0,
                narrative_blocks: profile?.narrative_blocks || 0,
                structure_nodes: profile?.structure_nodes || 0,
                total_pages: profile?.total_pages || 0,
            };
        }

        function safeArray(value) {
            return Array.isArray(value) ? value : [];
        }

        function displayCompanyName(value) {
            const name = (value || '').trim();
            return name || '未记录公司';
        }

        function formatDurationValue(seconds) {
            const s = Number(seconds);
            if (!Number.isFinite(s)) return '—';
            if (s >= 3600) return `${Math.floor(s / 3600)}时${Math.floor((s % 3600) / 60)}分`;
            if (s >= 60) return `${Math.floor(s / 60)}分${Math.round(s % 60)}秒`;
            return `${s.toFixed(1)}秒`;
        }

        function auditState(summary) {
            const hasSummary = !!summary && Object.keys(summary).length > 0;
            const labels = labelsForMode(summary?.check_mode || currentJob?.check_mode || 'ah');
            const isBilingual = labels.mode === 'h_bilingual';
            const real = Number(summary?.real_diff_count ?? 0);
            const warning = Number(summary?.warning_count ?? 0);
            const blocking = Number(summary?.blocking_warning_count ?? summary?.core_warning_count ?? warning);
            const auxiliary = Number(summary?.aux_warning_count ?? 0);
            const stale = !!summary?.stale_result;
            if (!hasSummary) {
                return {
                    key: 'empty',
                    pill: '黄色 · 暂无结果',
                    title: '核查结果尚未生成',
                    copy: '上传或打开历史记录后，这里会优先展示审计结论、风险信号和证据入口。'
                };
            }
            if (stale) {
                return {
                    key: 'stale',
                    pill: '黄色 · 建议重跑',
                    title: '历史结果来自旧提取引擎',
                    copy: `当前结果使用旧版提取逻辑生成。请用最新引擎重新核查，再判断核心提取完整性和真实差异。`
                };
            }
            if (real === 0 && blocking === 0) {
                return {
                    key: 'clean',
                    pill: auxiliary ? '绿色 · 核心提取完整' : '绿色 · 无风险信号',
                    title: auxiliary ? '核心提取完整，存在辅助提取提示' : '未发现真实差异或核心提取预警',
                    copy: auxiliary
                        ? (isBilingual
                            ? `中文原文扫描与核心事实抽取已完成；另有英文翻译语义提示 ${auxiliary} 条，不影响确定性数字核对。`
                            : `A/H 全页扫描与核心表提取完整；另有辅助图表提示 ${auxiliary} 条，不影响文本和表格核查完整性。`)
                        : (isBilingual
                            ? '中文原文数字、金额、日期、比例和英文翻译证据定位已生成，可继续查看翻译问题或抽样复核证据。'
                            : 'A/H 画像、披露覆盖和证据定位已生成，可继续查看画像或抽样复核证据。')
                };
            }
            return {
                key: 'risk',
                pill: '红色 · 需复核',
                title: '发现真实差异或核心提取预警',
                copy: `真实差异 ${real} 条，核心提取预警 ${blocking} 条，辅助提示 ${auxiliary} 条，建议优先进入证据审阅。`
            };
        }

        function updateResultTabCounts(summary) {
            const evidenceCount = safeArray(allDiffs).filter(d => evidenceForDiff(d).length).length;
            const counts = {
                tabCountProfileA: summary.a_fact_count || 0,
                tabCountProfileH: summary.h_fact_count || 0,
                tabCountRealDiff: summary.real_diff_count || 0,
                tabCountExpectedDiff: summary.expected_diff_count || 0,
                tabCountCoverage: summary.coverage_count ?? allCoverage.length,
                tabCountEvidence: evidenceCount,
            };
            Object.entries(counts).forEach(([id, value]) => {
                const el = document.getElementById(id);
                if (el) el.textContent = value;
            });
        }

        function renderAuditStrip(summary, job) {
            const strip = document.getElementById('auditStrip');
            if (!strip) return;
            const state = auditState(summary);
            const companyName = displayCompanyName(job?.company_name);
            strip.className = `audit-strip active ${state.key}`;
            const warning = Number(summary.warning_count || 0);
            const blocking = Number(summary.blocking_warning_count ?? summary.core_warning_count ?? warning);
            const auxiliary = Number(summary.aux_warning_count || 0);
            const evidenceCount = safeArray(allDiffs).filter(d => evidenceForDiff(d).length).length;
            const labels = sideLabelsForJob(job);
            strip.innerHTML = `
                <div class="audit-main">
                    <div class="audit-kicker">Audit Conclusion</div>
                    <div class="audit-company">
                        <span>公司</span>
                        <strong title="${escapeHtml(companyName)}">${escapeHtml(companyName)}</strong>
                    </div>
                    <div class="audit-head">
                        <div>
                            <div class="audit-title">${escapeHtml(state.title)}</div>
                            <div class="audit-copy">${escapeHtml(state.copy)}</div>
                        </div>
                    </div>
                    <div class="audit-chips">
                        <span class="audit-chip">${escapeHtml(labels.aFact)} <strong>${summary.a_fact_count || 0}</strong></span>
                        <span class="audit-chip">${escapeHtml(labels.hFact)} <strong>${summary.h_fact_count || 0}</strong></span>
                        <span class="audit-chip">${escapeHtml(labels.coverageTab)} <strong>${summary.coverage_count ?? allCoverage.length}</strong></span>
                        <span class="audit-chip">跨页事件 <strong>${summary.matched_event_count || 0}</strong></span>
                        <span class="audit-chip">核心预警 <strong>${blocking}</strong></span>
                        <span class="audit-chip">辅助提示 <strong>${auxiliary}</strong></span>
                        <span class="audit-chip">证据项 <strong>${evidenceCount}</strong></span>
                    </div>
                </div>
                <div class="audit-status">
                    <span class="audit-pill ${state.key}">${escapeHtml(state.pill)}</span>
                </div>
            `;
        }

        function renderDashboardCards(summary, job) {
            const box = document.getElementById('dashboard');
            if (!box) return;
            const labels = sideLabelsForJob(job);
            const isBilingual = labels.mode === 'h_bilingual';
            const real = Number(summary.real_diff_count || 0);
            const expected = Number(summary.expected_diff_count || 0);
            const warnings = Number(summary.warning_count || 0);
            const blocking = Number(summary.blocking_warning_count ?? summary.core_warning_count ?? warnings);
            const auxiliary = Number(summary.aux_warning_count || 0);
            const coverage = summary.coverage_count ?? allCoverage.length;
            box.innerHTML = `
                <div class="metric-card accent">
                    <div class="metric-label">${isBilingual ? '中文原文事实' : '画像'}</div>
                    <div class="metric-value">${summary.a_fact_count || 0} / ${summary.h_fact_count || 0}</div>
                    <div class="metric-sub">${escapeHtml(labels.A)}/${escapeHtml(labels.H)} 事实数 · Key ${summary.a_metric_keys || 0} / ${summary.h_metric_keys || 0}</div>
                </div>
                <div class="metric-card ${real ? 'critical' : ''}">
                    <div class="metric-label">差异</div>
                    <div class="metric-value">${real} / ${expected}</div>
                    <div class="metric-sub">真实 / 预期 · 内部 ${summary.internal_inconsistency_count || 0}</div>
                </div>
                <div class="metric-card accent">
                    <div class="metric-label">${isBilingual ? '待复核项' : '披露覆盖'}</div>
                    <div class="metric-value">${coverage}</div>
                    <div class="metric-sub">跨页 ${summary.matched_event_count || 0} · 单边 ${escapeHtml(labels.A)} ${summary.a_only_count || 0} / ${escapeHtml(labels.H)} ${summary.h_only_count || 0}</div>
                </div>
                <div class="metric-card ${blocking ? 'high' : ''}">
                    <div class="metric-label">提取预警</div>
                    <div class="metric-value">${blocking} / ${auxiliary}</div>
                    <div class="metric-sub">核心 / 辅助 · 总计 ${warnings}</div>
                </div>
                <div class="metric-card duration">
                    <div class="metric-label">耗时</div>
                    <div class="metric-value">${formatDurationValue(job?.duration_seconds)}</div>
                    <div class="metric-sub">总差异 ${summary.total_diff_count || 0} · 事件事实差异 ${summary.event_fact_diff_count || 0}</div>
                </div>
            `;
        }

        function formatPageList(pages) {
            const list = safeArray(pages).filter((page) => page !== null && page !== undefined && page !== '');
            if (!list.length) return '—';
            return list.map((page) => `p${page}`).join(' · ');
        }

        function setLaunchPanelVisible(visible) {
            const panel = document.getElementById('launchPanel');
            if (!panel) return;
            panel.classList.toggle('hidden', !visible);
        }

        function closeEvidenceReview() {
            const overlay = document.getElementById('reviewOverlay');
            if (overlay) {
                overlay.classList.remove('active');
                overlay.setAttribute('aria-hidden', 'true');
            }
            document.body.classList.remove('review-open');
            activeReviewItem = null;
            activeReviewEvidenceIndex = 0;
        }

        function focusReviewSource() {
            const view = activeReviewSourceView || 'diffs';
            closeEvidenceReview();
            setResultView(view);
        }

        function reviewBadgeHtml(text, cls) {
            return `<span class="badge ${cls || 'badge-info'}">${escapeHtml(text || '—')}</span>`;
        }

        function renderReviewMeta(entries) {
            return safeArray(entries).map((entry) => `
                <div class="review-meta-item">
                    <div class="review-meta-label">${escapeHtml(entry.label || '—')}</div>
                    <div class="review-meta-value">${entry.html ? entry.html : escapeHtml(entry.value === null || entry.value === undefined || entry.value === '' ? '—' : String(entry.value))}</div>
                </div>
            `).join('');
        }

        function reviewEvidenceSideLabel(side) {
            const labels = sideLabelsForJob(currentJob);
            if (side === 'A') return `${labels.A} 侧`;
            if (side === 'H') return `${labels.H} 侧`;
            return '证据';
        }

        function reviewSummaryChip(label, value, cls) {
            const safeValue = value === null || value === undefined || value === '' ? '—' : String(value);
            return `<span class="review-summary-chip ${cls || ''}"><span>${escapeHtml(label || '—')}</span><strong>${escapeHtml(safeValue)}</strong></span>`;
        }

        function reviewToneFromModel(model) {
            if (model && model.summaryTone) return model.summaryTone;
            const statusClass = model?.statusClass || '';
            if (statusClass.includes('real')) return 'risk';
            if (statusClass.includes('expected')) return 'expected';
            if (statusClass.includes('unresolved')) return 'coverage';
            return model?.kind === 'coverage' ? 'coverage' : 'coverage';
        }

        function reviewPagesBySide(evidences) {
            const labels = sideLabelsForJob(currentJob);
            const a = [];
            const h = [];
            for (const ev of safeArray(evidences)) {
                if (ev.page == null || ev.page === '') continue;
                if (ev.side === 'A') a.push(`${labels.A}p${ev.page}`);
                else if (ev.side === 'H') h.push(`${labels.H}p${ev.page}`);
            }
            return {
                a: a.join(' · ') || '—',
                h: h.join(' · ') || '—',
            };
        }

        function explanationForDiff(diff) {
            if (!diff) return null;
            const explanation = diff.diff_explanation || diff.diffExplanation || null;
            if (explanation) return { ...explanation, legacy: false };
            const topic = diff.topic || {};
            const summary = diff.summary || {};
            return {
                headline: topic.zh || topic.en || diff.canonical_key || '差异说明',
                issue: summary.zh || summary.en || '旧结果未记录结构化解释',
                location: formatEvidencePages(diff) || '',
                items: [],
                review_hint: '旧结果未记录结构化解释',
                legacy: true
            };
        }

        function explanationHeadline(diff) {
            const explanation = explanationForDiff(diff);
            return explanation?.headline || '差异说明';
        }

        function explanationIssue(diff) {
            const explanation = explanationForDiff(diff);
            return explanation?.issue || '旧结果未记录结构化解释';
        }

        function explanationLocation(diff) {
            const explanation = explanationForDiff(diff);
            return explanation?.location || formatEvidencePages(diff) || '—';
        }

        function explanationValue(value) {
            if (value === null || value === undefined || value === '') return '—';
            if (typeof value === 'number') return fmtNum(value);
            return String(value);
        }

        function renderExplanationItems(items) {
            const rows = safeArray(items);
            const labels = sideLabelsForJob(currentJob);
            if (!rows.length) {
                return '<div class="explanation-legacy">旧结果未记录结构化解释</div>';
            }
            return rows.map((item) => `
                <div class="review-explanation-grid">
                    <div class="review-explanation-card">
                        <div class="review-explanation-label">${escapeHtml(labels.A)} ${escapeHtml(item.label || '取值')} · ${item.a_page ? `第${escapeHtml(String(item.a_page))}页` : '未定位页码'}</div>
                        <div class="review-explanation-value">${escapeHtml(explanationValue(item.a_value))}</div>
                        <div class="review-explanation-snippet">${escapeHtml(item.a_snippet || '—')}</div>
                    </div>
                    <div class="review-explanation-card h-side">
                        <div class="review-explanation-label">${escapeHtml(labels.H)} ${escapeHtml(item.label || '取值')} · ${item.h_page ? `第${escapeHtml(String(item.h_page))}页` : '未定位页码'}</div>
                        <div class="review-explanation-value">${escapeHtml(explanationValue(item.h_value))}</div>
                        <div class="review-explanation-snippet">${escapeHtml(item.h_snippet || '—')}</div>
                    </div>
                </div>
            `).join('');
        }

        function renderDiffExplanationCell(diff) {
            const explanation = explanationForDiff(diff);
            return `
                <div class="explanation-cell">
                    <div class="explanation-head">${escapeHtml(explanation?.headline || '差异说明')}</div>
                    <div class="explanation-issue">${escapeHtml(explanation?.issue || '—')}</div>
                    ${explanation?.legacy ? '<div class="explanation-legacy">旧结果未记录结构化解释</div>' : ''}
                </div>
            `;
        }

        function renderReviewSummaryStrip(model) {
            const labels = sideLabelsForJob(currentJob);
            return [
                reviewSummaryChip('类型', model.kindLabel || '—'),
                reviewSummaryChip('结论', model.statusLabel || '—', reviewToneFromModel(model)),
                reviewSummaryChip(`${labels.A} 页码`, model.aPagesText || '—'),
                reviewSummaryChip(`${labels.H} 页码`, model.hPagesText || '—'),
                reviewSummaryChip('证据', String(model.evidenceCount ?? 0)),
                reviewSummaryChip(model.riskLabel || '严重性', model.riskValue || '—')
            ].join('');
        }

        function renderReviewEvidence(items, selectedIndex = 0) {
            const evidences = safeArray(items);
            if (!evidences.length) {
                return '<div class="text-muted" style="padding:0.25rem 0;">暂无证据</div>';
            }
            return evidences.map((ev, index) => {
                const isH = ev.side === 'H';
                const selected = index === selectedIndex;
                const sideLabel = reviewEvidenceSideLabel(ev.side);
                const page = ev.page != null ? `p${ev.page}` : 'p—';
                const section = ev.section ? ` · ${escapeHtml(ev.section)}` : '';
                const bbox = ev.bbox ? `<div class="review-bbox">bbox ${escapeHtml(JSON.stringify(ev.bbox))}</div>` : '';
                return `
                    <button type="button" class="review-evidence-card ${isH ? 'h-side' : 'a-side'} ${selected ? 'active' : ''}" onclick="selectReviewEvidence(${index})" aria-pressed="${selected ? 'true' : 'false'}">
                        <div class="review-evidence-top">
                            <span class="review-evidence-meta"><span class="review-evidence-index">${String(index + 1).padStart(2, '0')}</span><span>${sideLabel}</span></span>
                            <span>${escapeHtml(page)}${section}</span>
                        </div>
                        <div class="review-snippet">${escapeHtml(ev.snippet || '—')}</div>
                        ${bbox}
                    </button>
                `;
            }).join('');
        }

        function renderReviewCurrentEvidence(model, ev, index, total) {
            const tone = reviewToneFromModel(model);
            if (!ev) {
                return `
                    <div class="review-current-card ${tone}">
                        <div class="review-current-head">
                            <div>
                                <div class="review-current-title">当前证据</div>
                                <div class="review-current-empty">暂无可切换证据。</div>
                            </div>
                        </div>
                    </div>
                `;
            }
            const sideLabel = reviewEvidenceSideLabel(ev.side);
            const pageLabel = ev.page != null ? `第 ${ev.page} 页` : '—';
            const sectionLabel = ev.section ? ev.section : '未标注章节';
            const bboxLabel = ev.bbox ? `bbox ${JSON.stringify(ev.bbox)}` : '';
            return `
                <div class="review-current-card ${tone} ${ev.side === 'H' ? 'h-side' : ''}">
                    <div class="review-current-head">
                        <div>
                            <div class="review-current-title">当前证据 ${index + 1}/${total}</div>
                            <div class="review-current-empty">点击左侧证据可切换审阅片段。</div>
                        </div>
                        <div class="review-current-meta">
                            <span class="review-summary-chip ${ev.side === 'H' ? 'h-side' : 'a-side'}">${escapeHtml(sideLabel)}</span>
                            <span class="review-summary-chip">页码 <strong>${escapeHtml(pageLabel)}</strong></span>
                            <span class="review-summary-chip">章节 <strong>${escapeHtml(sectionLabel)}</strong></span>
                        </div>
                    </div>
                    <div class="review-current-snippet">${escapeHtml(ev.snippet || '—')}</div>
                    ${bboxLabel ? `<div class="review-current-bbox">${escapeHtml(bboxLabel)}</div>` : ''}
                </div>
            `;
        }

        function selectReviewEvidence(index) {
            if (!activeReviewItem) return;
            const evidences = safeArray(activeReviewItem.evidence);
            if (!evidences.length) return;
            activeReviewEvidenceIndex = Math.max(0, Math.min(index, evidences.length - 1));
            syncReviewEvidenceView();
        }

        function syncReviewEvidenceView() {
            if (!activeReviewItem) return;
            const evidences = safeArray(activeReviewItem.evidence);
            const selectedIndex = Math.max(0, Math.min(activeReviewEvidenceIndex, Math.max(evidences.length - 1, 0)));
            activeReviewEvidenceIndex = selectedIndex;
            const listEl = document.getElementById('reviewEvidenceList');
            const currentEl = document.getElementById('reviewCurrentEvidence');
            const chainCountEl = document.getElementById('reviewChainCount');
            if (chainCountEl) {
                const labels = sideLabelsForJob(currentJob);
                const aCount = evidences.filter((ev) => ev.side === 'A').length;
                const hCount = evidences.filter((ev) => ev.side === 'H').length;
                chainCountEl.textContent = `${labels.A} ${aCount} / ${labels.H} ${hCount}`;
            }
            if (listEl) listEl.innerHTML = renderReviewEvidence(evidences, selectedIndex);
            if (currentEl) currentEl.innerHTML = renderReviewCurrentEvidence(activeReviewItem, evidences[selectedIndex], selectedIndex, evidences.length);
        }

        function openReviewOverlay(model, selectedIndex = 0) {
            activeReviewItem = model;
            activeReviewKind = model.kind || 'diff';
            activeReviewEvidenceIndex = selectedIndex;
            const overlay = document.getElementById('reviewOverlay');
            if (!overlay) return;

            document.getElementById('reviewEyebrow').textContent = model.eyebrow || '证据审阅';
            document.getElementById('reviewTitle').textContent = model.title || '—';
            document.getElementById('reviewSubhead').textContent = model.subhead || '—';
            const summaryStrip = document.getElementById('reviewSummaryStrip');
            if (summaryStrip) summaryStrip.innerHTML = renderReviewSummaryStrip(model);
            document.getElementById('reviewTypeLabel').textContent = model.typeLabel || '差异';
            document.getElementById('reviewSummary').textContent = model.summary || '—';
            const explanationItems = document.getElementById('reviewExplanationItems');
            if (explanationItems) explanationItems.innerHTML = model.explanationHtml || '';
            document.getElementById('reviewAValue').textContent = model.aValue || '—';
            document.getElementById('reviewHValue').textContent = model.hValue || '—';
            document.getElementById('reviewADelta').textContent = model.aDelta || '';
            document.getElementById('reviewHDelta').textContent = model.hDelta || '';
            document.getElementById('reviewBadges').innerHTML = safeArray(model.badges).map((b) => reviewBadgeHtml(b.text, b.cls)).join('');
            document.getElementById('reviewMetaGrid').innerHTML = renderReviewMeta(model.meta);
            syncReviewEvidenceView();

            const reasoningWrap = document.getElementById('reviewReasoningWrap');
            const reasoningBox = document.getElementById('reviewReasoning');
            if (model.reasoningHtml) {
                reasoningWrap.style.display = 'block';
                reasoningBox.innerHTML = model.reasoningHtml;
            } else {
                reasoningWrap.style.display = 'none';
                reasoningBox.innerHTML = '';
            }

            const chartWrap = document.getElementById('reviewChartWrap');
            const chartBox = document.getElementById('reviewChart');
            if (model.chartHtml) {
                chartWrap.style.display = 'block';
                chartBox.innerHTML = model.chartHtml;
            } else {
                chartWrap.style.display = 'none';
                chartBox.innerHTML = '';
            }

            overlay.classList.add('active');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.classList.add('review-open');
        }

        function openDiffReview(diff) {
            if (!diff) return;
            if (diff.triage === 'real' || diff.triage === 'expected') activeTriage = diff.triage;
            activeReviewSourceView = 'diffs';
            const labels = sideLabelsForJob(currentJob);
            const topic = diff.topic || {};
            const summary = diff.summary || {};
            const explanation = explanationForDiff(diff);
            const explanationItems = safeArray(explanation?.items);
            const primaryItem = explanationItems[0] || null;
            const evidences = safeArray(diff.evidence);
            const evidencePages = reviewPagesBySide(evidences);
            const triage = diff.triage || 'real';
            const summaryTone = triage === 'real' ? 'risk' : (triage === 'expected' ? 'expected' : 'coverage');
            const confidenceText = diff.standard_reasoning
                ? `${((diff.standard_reasoning.confidence || 0) * 100).toFixed(0)}%`
                : (diff.severity || '—');
            const a = Number(diff.a_value);
            const h = Number(diff.h_value);
            const aValid = Number.isFinite(a);
            const hValid = Number.isFinite(h);
            const aDelta = aValid && hValid && a !== 0 ? `差异率 ${(Math.abs((h - a) / Math.abs(a)) * 100).toFixed(2)}%` : '';
            const hDelta = aValid && hValid ? `差额 ${fmtNum(h - a)}` : '';
            const reasoning = diff.standard_reasoning ? `
                <div style="display:grid; gap:0.6rem;">
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap;">
                        <span class="badge ${diff.standard_reasoning.expected ? 'badge-expected' : 'badge-high'}">${diff.standard_reasoning.expected ? '符合预期差异' : '不符合预期差异'}</span>
                        <span class="review-meta-value">置信度 ${((diff.standard_reasoning.confidence || 0) * 100).toFixed(0)}%</span>
                    </div>
                    <p style="color:var(--text-secondary); line-height:1.65; margin:0;">${escapeHtml(diff.standard_reasoning.rationale || '—')}</p>
                    ${(diff.standard_reasoning.citations || []).length ? `
                        <div class="review-meta-grid">
                            ${(diff.standard_reasoning.citations || []).map((c) => `
                                <div class="review-meta-item">
                                    <div class="review-meta-label">${escapeHtml(c.standard_code || '标准')}</div>
                                    <div class="review-meta-value">${escapeHtml([c.clause, c.title].filter(Boolean).join(' · ') || '—')}</div>
                                </div>
                            `).join('')}
                        </div>
                    ` : ''}
                </div>
            ` : '';
            const chart = diff.chart_cross ? `
                <div class="review-meta-grid">
                    <div class="review-meta-item"><div class="review-meta-label">图表值</div><div class="review-meta-value">${escapeHtml(fmtNum(diff.chart_cross.chart_value))}</div></div>
                    <div class="review-meta-item"><div class="review-meta-label">表格值</div><div class="review-meta-value">${escapeHtml(fmtNum(diff.chart_cross.table_value))}</div></div>
                    <div class="review-meta-item"><div class="review-meta-label">文本值</div><div class="review-meta-value">${escapeHtml(fmtNum(diff.chart_cross.text_value))}</div></div>
                    <div class="review-meta-item"><div class="review-meta-label">不一致数</div><div class="review-meta-value">${escapeHtml(String(diff.chart_cross.inconsistency_count || 0))}</div></div>
                </div>
            ` : '';

            openReviewOverlay({
                kind: 'diff',
                eyebrow: '真实差异 / 预期差异',
                title: explanation?.headline || topic.zh || topic.en || diff.canonical_key || '差异详情',
                subhead: `Diff ID: ${diff.diff_id} · ${explanationLocation(diff)} · ${evidences.length} 条证据`,
                kindLabel: diff.diff_type || 'diff',
                statusLabel: triageLabel(triage),
                statusClass: triageClass(triage),
                summaryTone,
                aPagesText: evidencePages.a,
                hPagesText: evidencePages.h,
                evidenceCount: evidences.length,
                riskLabel: diff.standard_reasoning ? '置信度' : '严重性',
                riskValue: confidenceText,
                typeLabel: diff.diff_type || 'diff',
                summary: explanation?.issue || summary.zh || summary.en || '—',
                explanationHtml: renderExplanationItems(explanationItems),
                aValue: primaryItem ? explanationValue(primaryItem.a_value) : fmtNum(diff.a_value),
                hValue: primaryItem ? explanationValue(primaryItem.h_value) : fmtNum(diff.h_value),
                aDelta: primaryItem?.a_page ? `${labels.A} 第${primaryItem.a_page}页` : aDelta,
                hDelta: primaryItem?.h_page ? `${labels.H} 第${primaryItem.h_page}页${primaryItem.delta !== null && primaryItem.delta !== undefined ? ` · 差额 ${explanationValue(primaryItem.delta)}` : ''}` : hDelta,
                badges: [
                    { text: triageLabel(triage), cls: triageClass(triage) },
                    { text: diff.severity || 'info', cls: sevClass(diff.severity) },
                    { text: diff.diff_type || 'diff', cls: typeClass(diff.diff_type) }
                ],
                evidence: evidences,
                meta: [
                    { label: '主题', value: topic.zh || topic.en || diff.canonical_key || '—' },
                    { label: '页码定位', value: explanationLocation(diff) || '—' },
                    { label: '规则 ID', value: diff.rule_id || '—' },
                    { label: '证据数', value: String(evidences.length) },
                    { label: `${labels.A}/${labels.H} 取值`, value: `${primaryItem ? explanationValue(primaryItem.a_value) : fmtNum(diff.a_value)} / ${primaryItem ? explanationValue(primaryItem.h_value) : fmtNum(diff.h_value)}` },
                    { label: '审阅提示', value: explanation?.review_hint || '—' },
                    { label: '差异类型', value: diff.diff_type || '—' }
                ],
                reasoningHtml: reasoning,
                chartHtml: chart
            });
        }

        function openCoverageReviewByIndex(index) {
            const item = safeArray(allCoverage)[index];
            if (!item) return;
            activeReviewSourceView = 'coverage';
            const labels = sideLabelsForJob(currentJob);
            const topic = item.topic || {};
            const evidences = [...safeArray(item.a_evidence), ...safeArray(item.h_evidence)];
            const aPagesText = formatPageList(item.a_pages);
            const hPagesText = formatPageList(item.h_pages);
            const status = coverageStatusLabel(item.status);
            const confidence = Number(item.match_confidence || 0).toFixed(2);
            openReviewOverlay({
                kind: 'coverage',
                eyebrow: '披露覆盖 / 未匹配项',
                title: topic.zh || topic.en || item.canonical_key || '覆盖项',
                subhead: `Coverage ID: ${item.coverage_id || '—'} · ${evidences.length} 条证据`,
                kindLabel: item.category || 'coverage',
                statusLabel: status,
                statusClass: coverageStatusClass(item.status),
                summaryTone: item.status === 'matched' ? 'expected' : 'coverage',
                aPagesText,
                hPagesText,
                evidenceCount: evidences.length,
                riskLabel: '匹配置信度',
                riskValue: confidence,
                typeLabel: item.category || 'coverage',
                summary: item.note || '—',
                aValue: aPagesText,
                hValue: hPagesText,
                aDelta: `${labels.A} 侧证据 ${safeArray(item.a_evidence).length} 条`,
                hDelta: `${labels.H} 侧证据 ${safeArray(item.h_evidence).length} 条`,
                badges: [
                    { text: status, cls: coverageStatusClass(item.status) },
                    { text: item.category || 'coverage', cls: coverageCategoryClass(item.category) }
                ],
                evidence: evidences,
                meta: [
                    { label: '状态', value: status },
                    { label: '类别', value: item.category || '—' },
                    { label: '匹配置信度', value: confidence },
                    { label: `${labels.A} 页码`, value: aPagesText },
                    { label: `${labels.H} 页码`, value: hPagesText },
                    { label: '说明', value: item.note || '—' }
                ]
            });
        }

        function summarizeOccurrences(occ) {
            const items = safeArray(occ.all_occurrences);
            return items.map(item => {
                const parts = [];
                if (item.page) parts.push(`p${item.page}`);
                if (item.unit) parts.push(item.unit);
                if (item.currency) parts.push(item.currency);
                if (item.value_text && item.value_text !== String(item.value ?? '')) parts.push(item.value_text);
                return parts.join(' ');
            }).join(' | ');
        }

        function renderProfileStats(containerId, profile) {
            const box = document.getElementById(containerId);
            if (!box) return;
            const s = countsForProfile(profile);
            const audit = profile?.extraction_audit || {};
            const scanned = safeArray(audit.scanned_pages).length;
            const total = audit.total_pages || s.total_pages || 0;
            const coverage = Number(audit.coverage_ratio ?? (total ? scanned / total : 0));
            const warnCount = safeArray(audit.warning_flags).length || safeArray(audit.warnings).length;
            const warningDetails = safeArray(audit.engines?.warning_details);
            const blockingCount = warningDetails.filter(item => item?.blocking).length;
            const auxiliaryCount = warningDetails.filter(item => item?.category === 'auxiliary_chart').length;
            box.innerHTML = `
                <div class="metric-card accent"><div class="metric-label">总页数</div><div class="metric-value">${s.total_pages}</div></div>
                <div class="metric-card"><div class="metric-label">扫描页数</div><div class="metric-value">${scanned || 0}/${total || 0}</div></div>
                <div class="metric-card"><div class="metric-label">覆盖率</div><div class="metric-value">${Number.isFinite(coverage) ? (coverage * 100).toFixed(1) + '%' : '—'}</div></div>
                <div class="metric-card"><div class="metric-label">指标 Key</div><div class="metric-value">${s.metric_keys}</div></div>
                <div class="metric-card"><div class="metric-label">事实出现</div><div class="metric-value">${s.metric_occurrences}</div></div>
                <div class="metric-card"><div class="metric-label">叙述块</div><div class="metric-value">${s.narrative_blocks}</div></div>
                <div class="metric-card ${blockingCount ? 'high' : ''}"><div class="metric-label">提取预警</div><div class="metric-value">${blockingCount} / ${auxiliaryCount}</div><div class="metric-sub">核心 / 辅助 · 总计 ${warnCount}</div></div>
            `;
        }

        function renderWarningPanel(summary) {
            const panel = document.getElementById('warningPanel');
            if (!panel) return;
            const warnings = safeArray(summary?.warnings);
            if (!warnings.length) {
                panel.classList.remove('active');
                panel.innerHTML = '';
                return;
            }
            panel.innerHTML = `
                <div class="warn-title">提取提示 ${warnings.length} 条：核心预警影响完整性，辅助提示和旧引擎结果单独展示</div>
                <div class="warn-grid">
                    ${warnings.slice(0, 8).map(item => `
                        <div class="warn-item">
                            <div>
                                <strong>${escapeHtml(item.side || '')} · ${escapeHtml(item.flag || 'warning')} · ${escapeHtml(item.category || 'extraction')} · ${escapeHtml(item.severity || 'medium')}${item.blocking ? ' · 阻断' : ''}</strong>
                                ${escapeHtml(item.message || '')}
                                <br><span>pages ${escapeHtml(String(item.scanned_pages ?? 0))}/${escapeHtml(String(item.total_pages ?? 0))} · OCR ${escapeHtml(String(item.ocr_pages ?? 0))} · table pages ${escapeHtml(String(item.table_pages ?? 0))}</span>
                            </div>
                            <button class="warn-action" type="button" onclick="setResultView('evidence')">审阅证据</button>
                        </div>
                    `).join('')}
                </div>
            `;
            panel.classList.add('active');
        }

        function renderProfileMetrics(bodyId, countId, profile) {
            const body = document.getElementById(bodyId);
            const count = document.getElementById(countId);
            if (!body) return;
            const metrics = safeArray(profile?.metrics);
            if (count) count.textContent = `${metrics.length} 条指标`;
            body.innerHTML = metrics.map((m) => {
                const name = m.name?.zh || m.name?.en || m.canonical_key || '—';
                const unit = [m.unit, m.currency].filter(Boolean).join(' / ');
                const occ = safeArray(m.all_occurrences || []);
                const first = occ[0] || {};
                const allText = occ.map(item => {
                    const bits = [];
                    if (item.page) bits.push(`p${item.page}`);
                    if (item.value_text != null) bits.push(item.value_text);
                    else if (item.value != null) bits.push(fmtNum(item.value));
                    return bits.join(': ');
                }).join(' | ');
                return `
                    <tr>
                        <td><span class="main-text">${escapeHtml(m.canonical_key || '—')}</span></td>
                        <td><div class="main-text">${escapeHtml(name)}</div></td>
                        <td class="num"><strong>${fmtNum(m.value)}</strong><div class="sub">${escapeHtml(m.value_text || '')}</div></td>
                        <td>${escapeHtml(unit || '—')}</td>
                        <td>${escapeHtml(String(m.page || first.page || '—'))}</td>
                        <td>${escapeHtml(String(m.occurrence_count ?? occ.length ?? 0))}</td>
                        <td>${m.is_internally_consistent ? '是' : '否'}</td>
                        <td class="snippet">${escapeHtml(allText || '—')}</td>
                    </tr>
                `;
            }).join('') || `<tr><td colspan="8" class="text-muted">暂无数值画像</td></tr>`;
        }

        function renderProfileNarratives(bodyId, countId, profile) {
            const body = document.getElementById(bodyId);
            const count = document.getElementById(countId);
            if (!body) return;
            const narratives = safeArray(profile?.narratives);
            if (count) count.textContent = `${narratives.length} 个叙述块`;
            body.innerHTML = narratives.map((n) => {
                const segs = safeArray(n.segments);
                const first = segs[0] || {};
                const last = segs[segs.length - 1] || {};
                const range = n.page_range ? `${n.page_range[0]}-${n.page_range[1]}` : `${first.page || '—'}-${last.page || '—'}`;
                const segText = segs.map(seg => `p${seg.page}: ${seg.text || ''}`).join(' | ');
                return `
                    <tr>
                        <td><div class="main-text">${escapeHtml(n.topic_label || 'uncategorized')}</div></td>
                        <td>${escapeHtml(n.topic_key || 'uncategorized')}</td>
                        <td>${escapeHtml(range)}</td>
                        <td class="num">${escapeHtml(String(n.word_count ?? 0))}</td>
                        <td>${escapeHtml(n.detail_level || 'brief')}</td>
                        <td class="snippet">${escapeHtml(n.summary || '—')}</td>
                        <td class="snippet">${escapeHtml(segText || '—')}</td>
                    </tr>
                `;
            }).join('') || `<tr><td colspan="7" class="text-muted">暂无文字画像</td></tr>`;
        }

        function renderStructure(containerId, countId, profile) {
            const box = document.getElementById(containerId);
            const count = document.getElementById(countId);
            if (!box) return;
            const nodes = safeArray(profile?.structure);
            if (count) count.textContent = `${countStructureNodes(nodes)} 个节点`;
            box.innerHTML = renderStructureNodes(nodes, 0) || '<div class="text-muted">暂无结构树</div>';
        }

        function countStructureNodes(nodes) {
            return safeArray(nodes).reduce((sum, node) => sum + 1 + countStructureNodes(node.children || []), 0);
        }

        function renderStructureNodes(nodes, level) {
            return safeArray(nodes).map(node => {
                const title = node.title?.zh || node.title?.en || node.section_code || '—';
                const children = renderStructureNodes(node.children || [], level + 1);
                return `
                    <div class="structure-node" style="margin-left:${Math.max(level, 0) * 0.75}rem">
                        <span class="node-title">${escapeHtml(title)}</span>
                        <span class="node-meta">[${escapeHtml(node.section_code || 'root')}] ${escapeHtml(String(node.page_start || '—'))}-${escapeHtml(String(node.page_end || '—'))}</span>
                        ${children}
                    </div>
                `;
            }).join('');
        }

        function evidenceForDiff(d) {
            return safeArray(d?.evidence || []).map(ev => ({
                side: ev.side || '',
                page: ev.page || '',
                section: ev.section || '',
                bbox: ev.bbox || null,
                snippet: ev.snippet || '',
            }));
        }

        function formatEvidencePages(diff) {
            const pages = [];
            const labels = sideLabelsForJob(currentJob);
            for (const ev of safeArray(diff.evidence)) {
                if (ev.page) pages.push(`${ev.side === 'A' ? labels.A : labels.H}p${ev.page}`);
            }
            return pages.join(', ');
        }

        function profileSummaryData(profile, side) {
            if (!profile) return '';
            const s = countsForProfile(profile);
            return `
                <div class="metric-card accent"><div class="metric-label">侧别</div><div class="metric-value">${side}</div></div>
                <div class="metric-card"><div class="metric-label">总页数</div><div class="metric-value">${s.total_pages}</div></div>
                <div class="metric-card"><div class="metric-label">数值 Key</div><div class="metric-value">${s.metric_keys}</div></div>
                <div class="metric-card"><div class="metric-label">文字块</div><div class="metric-value">${s.narrative_blocks}</div></div>
            `;
        }

        function normalizedDiffs() {
            return safeArray(allDiffs).filter(d => (d.triage || 'real') === activeTriage);
        }

        function currentDiffsForDisplay() {
            return normalizedDiffs().filter(d => {
                const tOk = activeFilters.type === 'all' || d.diff_type === activeFilters.type;
                const sOk = activeFilters.sev === 'all' || d.severity === activeFilters.sev;
                return tOk && sOk;
            });
        }

        function isBilingualLayoutDiff(diff) {
            const ruleId = diff?.rule_id || '';
            return ruleId.startsWith('bilingual_section_') || ruleId.startsWith('bilingual_table_') || ruleId === 'bilingual_paragraph_unpaired';
        }

        function setResultView(view) {
            const mode = currentJob?.check_mode || currentJob?.comparison_summary?.check_mode || 'ah';
            if (mode === 'h_bilingual' && (view === 'profile-a' || view === 'profile-h')) {
                view = 'real-diff';
            }
            if (view === 'real-diff' || view === 'expected-diff') {
                activeTriage = view === 'real-diff' ? 'real' : 'expected';
                view = 'diffs';
                selectedDiffId = null;
                document.getElementById('detailPanel')?.classList.remove('active');
                renderDiffTable();
            }
            activeView = view;
            document.querySelectorAll('.view-tab').forEach(btn => {
                const btnView = btn.dataset.view;
                const isActive = (btnView === 'real-diff' && activeTriage === 'real' && view === 'diffs')
                    || (btnView === 'expected-diff' && activeTriage === 'expected' && view === 'diffs')
                    || btnView === view;
                btn.classList.toggle('active', isActive);
            });
            document.querySelectorAll('.view-pane').forEach(pane => {
                pane.classList.toggle('active', pane.id === `view-${view}`);
            });
        }

        function renderAllViews(job) {
            setLaunchPanelVisible(false);
            const summary = job.comparison_summary || {};
            const profileA = job.profile_a || {};
            const profileH = job.profile_h || {};
            allCoverage = safeArray(job.coverage_items);

            configureResultMode(job);
            document.getElementById('resultViewTabs').style.display = 'flex';
            updateResultTabCounts(summary);
            renderAuditStrip(summary, job);
            renderWarningPanel(summary);
            renderProfileStats('profileSummaryA', profileA);
            renderProfileStats('profileSummaryH', profileH);
            renderProfileMetrics('profileAMetricBody', 'profileACount', profileA);
            renderProfileMetrics('profileHMetricBody', 'profileHCount', profileH);
            renderProfileNarratives('profileANarrativeBody', 'profileANarrativeCount', profileA);
            renderProfileNarratives('profileHNarrativeBody', 'profileHNarrativeCount', profileH);
            renderStructure('profileAStructure', 'profileAStructureCount', profileA);
            renderStructure('profileHStructure', 'profileHStructureCount', profileH);
            renderDashboardCards(summary, job);

            renderDiffTable();
            renderCoverageTable();
            renderEvidenceTable();
        }

        async function startCheck() {
            const btn = document.getElementById('startBtn');
            if (btn.disabled) return;

            const validation = validateUploadInputs({ notify: true });
            if (!validation.ok) {
                checkReady();
                return;
            }
            const companyName = validation.companyName;
            const btnText = document.getElementById('btnText');
            btn.disabled = true;
            btn.setAttribute('aria-disabled', 'true');
            btnText.innerHTML = '<span class="spinner"></span> 处理中...';
            setStatus('处理中', 'processing');

            setLaunchPanelVisible(false);
            closeEvidenceReview();
            document.getElementById('progressSection').classList.add('active');
            document.getElementById('resultsSection').classList.remove('active');
            document.getElementById('dashboard').classList.remove('active');
            document.getElementById('auditStrip')?.classList.remove('active', 'clean', 'risk', 'empty');
            document.getElementById('warningPanel')?.classList.remove('active');
            updateProgress(5, '正在上传文件...', 'pending');

            const formData = new FormData();
            formData.append('company_name', companyName);
            formData.append('check_mode', getCheckMode());
            formData.append('a_file', files.A);
            formData.append('h_file', files.H);

            try {
                updateProgress(15, '上传完成，开始解析...', 'parsing');
                const resp = await fetch(`${API_BASE}/api/jobs/`, { method: 'POST', body: formData });
                if (!resp.ok) {
                    const err = await resp.text();
                    throw new Error(`HTTP ${resp.status}: ${err}`);
                }
                const job = normalizeJob(await resp.json());
                currentJob = job;

                if (job.status === 'done') updateProgress(100, '处理完成', 'done');
                else if (job.status === 'failed') {
                    updateProgress(0, '处理失败: ' + (job.error || '未知错误'), 'parsing');
                    document.querySelector('.stage.active')?.classList.add('error');
                    throw new Error(job.error || '任务失败');
                }
                if (job.progress?.length) {
                    const last = job.progress[job.progress.length - 1];
                    updateProgress(last.percent, last.message, last.stage);
                }

                allDiffs = job.diffs || [];
                allCoverage = job.coverage_items || [];
                selectedDiffId = null;
                activeTriage = 'real';
                setLaunchPanelVisible(false);
                closeEvidenceReview();
                renderAllViews(job);
                setResultView(defaultResultViewForJob(job));
                document.getElementById('resultsSection').classList.add('active');
                document.getElementById('dashboard').classList.add('active');
                setStatus('完成', 'done');
                syncHashToJob();
                showToast(`核查完成，识别 ${allDiffs.length} 条差异，${allCoverage.length} 项披露覆盖`, 'success');
                loadHistory();

                if (job.job_id) {
                    document.getElementById('downloadXlsx').href = `${API_BASE}/api/jobs/${job.job_id}/report.xlsx`;
                    document.getElementById('downloadPdf').href = `${API_BASE}/api/jobs/${job.job_id}/report.pdf`;
                }
            } catch (err) {
                console.error(err);
                setStatus('失败', 'error');
                showToast('核查失败: ' + err.message, 'error');
                updateProgress(0, '处理失败', 'parsing');
                document.querySelector('.stage.active')?.classList.add('error');
            } finally {
                btn.disabled = false;
                btnText.textContent = '启动核查';
                checkReady();
            }
        }

        function fmtNum(v) {
            if (v === null || v === undefined) return '—';
            if (Math.abs(v) >= 1e8) return (v / 1e8).toFixed(2) + ' 亿';
            if (Math.abs(v) >= 1e4) return (v / 1e4).toFixed(2) + ' 万';
            return v.toLocaleString('zh-CN');
        }

        function sevClass(s) {
            const m = { critical: 'badge-critical', high: 'badge-high', medium: 'badge-medium', low: 'badge-low', info: 'badge-info' };
            return m[s] || 'badge-info';
        }
        function typeClass(t) {
            const m = { numeric: 'badge-numeric', standard: 'badge-standard', disclosure: 'badge-disclosure', chart: 'badge-chart', cross_check: 'badge-cross_check', internal: 'badge-internal' };
            return m[t] || 'badge-info';
        }

        function coverageCategoryClass(category) {
            const m = {
                metric: 'badge-numeric',
                narrative: 'badge-standard',
                structure: 'badge-info',
                event: 'badge-disclosure',
                location: 'badge-low',
                depth_rule: 'badge-high'
            };
            return m[category] || 'badge-info';
        }

        function getFiltered() {
            return currentDiffsForDisplay();
        }

        function renderDiffTable() {
            const tbody = document.getElementById('diffTableBody');
            const diffs = getFiltered();
            const empty = document.getElementById('emptyState');
            const scroll = document.querySelector('#view-diffs .table-scroll');

            if (!diffs.length) {
                tbody.innerHTML = '';
                empty.style.display = 'block';
                scroll.style.display = 'none';
                return;
            }
            empty.style.display = 'none';
            scroll.style.display = 'block';

            tbody.innerHTML = diffs.map((d, i) => {
                const topic = d.topic || {};
                const topicText = topic.zh || topic.en || d.canonical_key || '—';
                const sub = d.canonical_key && topic.zh ? d.canonical_key : '';
                const pages = formatEvidencePages(d);
                const triage = d.triage || 'real';
                const sel = d.diff_id === selectedDiffId;
                return `
                    <tr class="${sel ? 'selected' : ''}" onclick="selectDiff('${d.diff_id}')">
                        <td class="col-narrow"><span style="color:var(--text-tertiary);font-size:0.75rem">${i+1}</span></td>
                        <td class="col-triage"><span class="badge ${triageClass(triage)}">${triageLabel(triage)}</span></td>
                        <td class="col-sev"><span class="badge ${sevClass(d.severity)}">${d.severity}</span></td>
                        <td class="col-type"><span class="badge ${typeClass(d.diff_type)}">${d.diff_type}</span></td>
                        <td class="col-explanation">${renderDiffExplanationCell(d)}</td>
                        <td class="col-topic">
                            <div class="topic-cell">${escapeHtml(topicText)}${sub ? `<div class="sub">${escapeHtml(sub)}</div>` : ''}</div>
                        </td>
                        <td class="col-num cell-num"><strong>${fmtNum(d.a_value)}</strong></td>
                        <td class="col-num cell-num"><strong>${fmtNum(d.h_value)}</strong></td>
                        <td class="col-pages">
                            <span class="page-tag">${ICONS.page}${escapeHtml(pages) || '—'}</span>
                        </td>
                        <td class="col-action">
                            <button class="row-review-btn" type="button" onclick="event.stopPropagation(); selectDiff('${d.diff_id}')">审阅证据</button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function renderCoverageTable() {
            const tbody = document.getElementById('coverageTableBody');
            const count = document.getElementById('coverageCount');
            if (!tbody) return;
            if (isBilingualJob(currentJob)) {
                const layoutDiffs = safeArray(allDiffs).filter(isBilingualLayoutDiff);
                if (count) count.textContent = `${layoutDiffs.length} 项章节排版`;
                tbody.innerHTML = layoutDiffs.map((diff, i) => {
                    const explanation = explanationForDiff(diff);
                    const evidences = evidenceForDiff(diff);
                    const aEv = evidences.filter(ev => ev.side === 'A');
                    const hEv = evidences.filter(ev => ev.side === 'H');
                    const renderSide = (items) => items.map(ev => {
                        const bbox = ev.bbox ? ` bbox=${JSON.stringify(ev.bbox)}` : '';
                        return `<div class="snippet"><strong>p${escapeHtml(String(ev.page || '—'))}</strong>${ev.section ? ` · ${escapeHtml(ev.section)}` : ''}${escapeHtml(bbox)}<br>${escapeHtml(ev.snippet || '—')}</div>`;
                    }).join('<hr style="border:0;border-top:1px solid var(--border-light);margin:0.45rem 0">') || '<span class="text-muted" style="padding:0">未定位</span>';
                    return `
                        <tr onclick="selectDiff('${diff.diff_id}')">
                            <td class="col-narrow">${i + 1}</td>
                            <td class="col-triage"><span class="badge ${triageClass(diff.triage || 'unresolved')}">${triageLabel(diff.triage || 'unresolved')}</span></td>
                            <td class="col-type"><span class="badge ${typeClass(diff.diff_type)}">${escapeHtml(diff.rule_id || 'layout')}</span></td>
                            <td class="col-topic"><div class="topic-cell">${escapeHtml(explanation?.headline || '章节排版')}</div></td>
                            <td>${renderSide(aEv)}</td>
                            <td>${renderSide(hEv)}</td>
                            <td class="col-pages"><span class="page-tag">${escapeHtml(diff.severity || '—')}</span></td>
                            <td class="col-topic"><div class="topic-cell">${escapeHtml(explanation?.issue || '—')}</div></td>
                            <td class="col-action">
                                <button class="row-review-btn" type="button" onclick="event.stopPropagation(); selectDiff('${diff.diff_id}')">审阅证据</button>
                            </td>
                        </tr>
                    `;
                }).join('') || `<tr><td colspan="9" class="text-muted">暂无章节排版差异</td></tr>`;
                return;
            }
            const items = safeArray(allCoverage);
            if (count) count.textContent = `${items.length} 项覆盖`;
            const renderSide = (items) => safeArray(items).map(ev => {
                const bbox = ev.bbox ? ` bbox=${JSON.stringify(ev.bbox)}` : '';
                return `<div class="snippet"><strong>p${escapeHtml(String(ev.page || '—'))}</strong>${ev.section ? ` · ${escapeHtml(ev.section)}` : ''}${escapeHtml(bbox)}<br>${escapeHtml(ev.snippet || '—')}</div>`;
            }).join('<hr style="border:0;border-top:1px solid var(--border-light);margin:0.45rem 0">') || '<span class="text-muted" style="padding:0">未匹配</span>';

            tbody.innerHTML = items.map((item, i) => {
                const topic = item.topic || {};
                const topicText = topic.zh || topic.en || item.canonical_key || '—';
                return `
                    <tr onclick="openCoverageReviewByIndex(${i})">
                        <td class="col-narrow">${i + 1}</td>
                        <td class="col-triage"><span class="badge ${coverageStatusClass(item.status)}">${coverageStatusLabel(item.status)}</span></td>
                        <td class="col-type"><span class="badge ${coverageCategoryClass(item.category)}">${escapeHtml(item.category || '—')}</span></td>
                        <td class="col-topic"><div class="topic-cell">${escapeHtml(topicText)}${item.canonical_key ? `<div class="sub">${escapeHtml(item.canonical_key)}</div>` : ''}</div></td>
                        <td>${renderSide(item.a_evidence)}</td>
                        <td>${renderSide(item.h_evidence)}</td>
                        <td class="col-pages"><span class="page-tag">${Number(item.match_confidence || 0).toFixed(2)}</span></td>
                        <td class="col-topic"><div class="topic-cell">${escapeHtml(item.note || '—')}</div></td>
                        <td class="col-action">
                            <button class="row-review-btn" type="button" onclick="event.stopPropagation(); openCoverageReviewByIndex(${i})">审阅证据</button>
                        </td>
                    </tr>
                `;
            }).join('') || `<tr><td colspan="9" class="text-muted">暂无披露覆盖项</td></tr>`;
        }

        function renderEvidenceTable() {
            const tbody = document.getElementById('evidenceTableBody');
            const count = document.getElementById('evidenceCount');
            if (!tbody) return;
            const diffs = safeArray(allDiffs).filter(d => evidenceForDiff(d).length);
            if (count) count.textContent = `${diffs.length} 条差异证据`;
            tbody.innerHTML = diffs.map((d, i) => {
                const topic = d.topic || {};
                const topicText = topic.zh || topic.en || d.canonical_key || '—';
                const evidences = evidenceForDiff(d);
                const aEv = evidences.filter(ev => ev.side === 'A');
                const hEv = evidences.filter(ev => ev.side === 'H');
                const renderSide = (items) => items.map(ev => {
                    const bbox = ev.bbox ? ` bbox=${JSON.stringify(ev.bbox)}` : '';
                    return `<div class="snippet"><strong>p${escapeHtml(String(ev.page || '—'))}</strong>${ev.section ? ` · ${escapeHtml(ev.section)}` : ''}${escapeHtml(bbox)}<br>${escapeHtml(ev.snippet || '—')}</div>`;
                }).join('<hr style="border:0;border-top:1px solid var(--border-light);margin:0.45rem 0">') || '<span class="text-muted" style="padding:0">未披露</span>';
                return `
                    <tr onclick="selectDiff('${d.diff_id}')">
                        <td class="col-narrow">${i + 1}</td>
                        <td class="col-triage"><span class="badge ${triageClass(d.triage || 'real')}">${triageLabel(d.triage || 'real')}</span></td>
                        <td class="col-type"><span class="badge ${typeClass(d.diff_type)}">${escapeHtml(d.diff_type || '—')}</span></td>
                        <td class="col-topic"><div class="topic-cell">${escapeHtml(topicText)}</div></td>
                        <td>${renderSide(aEv)}</td>
                        <td>${renderSide(hEv)}</td>
                        <td class="col-pages"><span class="page-tag">${ICONS.page}${escapeHtml(formatEvidencePages(d) || '—')}</span></td>
                    </tr>
                `;
            }).join('') || `<tr><td colspan="7" class="text-muted">暂无证据定位</td></tr>`;
        }

        function selectDiff(diffId) {
            selectedDiffId = diffId;
            renderDiffTable();
            const diff = allDiffs.find(d => d.diff_id === diffId);
            if (!diff) return;
            openDiffReview(diff);
            return;

            const panel = document.getElementById('detailPanel');
            panel.classList.add('active');

            const topic = diff.topic || {};
            document.getElementById('detailTitle').textContent = topic.zh || topic.en || diff.canonical_key || '差异详情';
            document.getElementById('detailMeta').textContent = 'ID: ' + diff.diff_id;
            document.getElementById('detailBadges').innerHTML = `
                <span class="badge ${triageClass(diff.triage || 'real')}">${triageLabel(diff.triage || 'real')}</span>
                <span class="badge ${sevClass(diff.severity)}">${diff.severity}</span>
                <span class="badge ${typeClass(diff.diff_type)}">${diff.diff_type}</span>
            `;

            const summary = diff.summary || {};
            document.getElementById('detailSummary').textContent = summary.zh || summary.en || '—';
            document.getElementById('detailAValue').textContent = fmtNum(diff.a_value);
            document.getElementById('detailHValue').textContent = fmtNum(diff.h_value);

            const a = Number(diff.a_value), h = Number(diff.h_value);
            if (!isNaN(a) && !isNaN(h) && a !== 0) {
                const delta = ((h - a) / Math.abs(a) * 100).toFixed(2);
                document.getElementById('detailADelta').textContent = `差异率 ${delta}%`;
                document.getElementById('detailHDelta').textContent = `差异额 ${fmtNum(h - a)}`;
            } else {
                document.getElementById('detailADelta').textContent = '';
                document.getElementById('detailHDelta').textContent = '';
            }

            // Evidence
            const evList = document.getElementById('evidenceList');
            evList.innerHTML = '';
            for (const ev of (diff.evidence || [])) {
                const isA = ev.side === 'A';
                const div = document.createElement('div');
                div.className = `ev-item ${isA ? '' : 'h-side'}`;
                div.innerHTML = `
                    <div class="ev-header">
                        <span class="ev-side">${isA ? labels.A : labels.H}</span>
                        <span class="ev-page">${ICONS.page}第 ${ev.page || '?'} 页${ev.section ? ` · ${escapeHtml(ev.section)}` : ''}</span>
                    </div>
                    <div class="ev-snippet">${escapeHtml(ev.snippet || '—')}</div>
                `;
                evList.appendChild(div);
            }

            // Reasoning
            const rs = document.getElementById('reasoningSection');
            if (diff.standard_reasoning) {
                rs.style.display = 'block';
                const sr = diff.standard_reasoning;
                const expected = sr.expected;
                const citations = (sr.citations || []).map(c =>
                    `<li>${escapeHtml(c.standard_code || '')} ${escapeHtml(c.clause || '')}: ${escapeHtml(c.title || '')}</li>`
                ).join('');
                document.getElementById('reasoningBox').innerHTML = `
                    <div class="r-header">
                        <span class="r-badge ${expected ? 'expected' : 'unexpected'}">${expected ? '符合预期差异' : '不符合预期'}</span>
                        <span class="r-confidence">置信度 ${((sr.confidence || 0) * 100).toFixed(0)}%</span>
                    </div>
                    <p>${escapeHtml(sr.rationale || '—')}</p>
                    ${citations ? `<ul class="citations">${citations}</ul>` : ''}
                `;
            } else rs.style.display = 'none';

            // Chart
            const cs = document.getElementById('chartCrossSection');
            if (diff.chart_cross) {
                cs.style.display = 'block';
                const cc = diff.chart_cross;
                document.getElementById('chartCrossContent').innerHTML = `
                    <div class="chart-grid">
                        <div class="chart-metric"><div class="cm-label">图表值</div><div class="cm-value">${fmtNum(cc.chart_value)}</div></div>
                        <div class="chart-metric"><div class="cm-label">表格值</div><div class="cm-value">${fmtNum(cc.table_value)}</div></div>
                        <div class="chart-metric"><div class="cm-label">文本值</div><div class="cm-value">${fmtNum(cc.text_value)}</div></div>
                        <div class="chart-metric"><div class="cm-label">不一致数</div><div class="cm-value">${cc.inconsistency_count || 0}</div></div>
                    </div>
                `;
            } else cs.style.display = 'none';

            panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function toggleFilter(kind, value) {
            activeFilters[kind] = value;
            document.querySelectorAll(`[data-${kind}]`).forEach(c => {
                c.classList.toggle('active', c.dataset[kind] === value);
            });
            renderDiffTable();
            const filtered = getFiltered();
            if (selectedDiffId && !filtered.find(d => d.diff_id === selectedDiffId)) {
                document.getElementById('detailPanel').classList.remove('active');
                selectedDiffId = null;
            }
        }

        // Drag & drop
        ['A', 'H'].forEach(side => {
            const box = document.getElementById('upload' + side);
            box.addEventListener('dragover', e => { e.preventDefault(); box.classList.add('drag-over'); });
            box.addEventListener('dragleave', e => { e.preventDefault(); box.classList.remove('drag-over'); });
            box.addEventListener('drop', e => {
                e.preventDefault();
                box.classList.remove('drag-over');
                const file = e.dataTransfer.files[0];
                if (file && file.type === 'application/pdf') {
                    files[side] = file;
                    const fn = document.getElementById('filename' + side);
                    fn.innerHTML = ICONS.file + '<span>' + escapeHtml(file.name) + '</span>';
                    box.classList.add('has-file');
                    checkReady();
                }
            });
        });

        // ── History ──
        async function loadHistory() {
            const section = document.getElementById('historySection');
            const count = document.getElementById('historyCount');
            const list = document.getElementById('historyList');
            if (list && !list.dataset.ready) {
                list.innerHTML = '<div class="history-empty">正在读取历史记录…</div>';
            }
            try {
                const resp = await fetch(`${API_BASE}/api/jobs/history?limit=10`);
                if (!resp.ok) throw new Error(`history request failed: ${resp.status}`);
                const jobs = await resp.json();
                section.classList.add('has-data');
                list.dataset.ready = '1';
                if (!jobs || !jobs.length) {
                    count.textContent = '0 条记录';
                    list.innerHTML = '<div class="history-empty">暂无历史记录</div>';
                    return;
                }
                count.textContent = `${jobs.length} 条记录`;

                list.innerHTML = jobs.map(j => {
                    const time = j.started_at ? new Date(j.started_at + 'Z').toLocaleString('zh-CN', { month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' }) : '';
                    let dur = '';
                    if (j.duration_seconds != null) {
                        const s = j.duration_seconds;
                        dur = s >= 60 ? (Math.floor(s/60) + '分' + Math.round(s%60) + '秒') : s.toFixed(1) + '秒';
                    }
                    const companyName = displayCompanyName(j.company_name);
                    const labels = sideLabelsForJob(j);
                    const aName = (j.a_file || '').split(/[\\/]/).pop() || '—';
                    const hName = (j.h_file || '').split(/[\\/]/).pop() || '—';
                    const summary = j.comparison_summary || {};
                    const realCount = Number(summary.real_diff_count ?? 0);
                    const coverageCount = summary.coverage_count ?? 0;
                    const warningCount = Number(summary.warning_count ?? 0);
                    const blockingWarningCount = Number(summary.blocking_warning_count ?? summary.core_warning_count ?? warningCount);
                    const auxiliaryWarningCount = Number(summary.aux_warning_count ?? 0);
                    const staleResult = !!summary.stale_result;
                    const hasUsableResult = !!summary && Object.keys(summary).length > 0;
                    const hasRiskSignal = realCount > 0 || warningCount > 0;
                    const cls = !hasUsableResult ? 'partial' : (hasRiskSignal ? 'failed' : 'done');
                    const statusLabel = j.status === 'failed' ? '任务状态：失败' : (j.status === 'done' ? '任务状态：完成' : `任务状态：${j.status || '未知'}`);
                    const badgeTitle = !hasUsableResult
                        ? `${statusLabel}，暂无可用核查结果`
                        : (staleResult
                            ? `${statusLabel}，旧提取引擎结果，建议重跑`
                            : hasRiskSignal
                            ? `${statusLabel}，发现真实差异或提取预警`
                            : `${statusLabel}，未发现真实差异或提取预警`);

                    return `
                        <div class="history-item" onclick="loadJobDetail('${j.job_id}')">
                            <div class="hi-row-main">
                                <div class="hi-main">
                                    <div class="hi-info">
                                        <div class="hi-company-line">
                                            <span class="hi-badge ${cls}" title="${escapeHtml(badgeTitle)}"></span>
                                            <div class="history-company" title="${escapeHtml(companyName)}">${escapeHtml(companyName)}</div>
                                        </div>
                                        <div class="hi-files" title="${escapeHtml(aName)} / ${escapeHtml(hName)}">
                                            <div class="hi-file-line"><span class="hi-file-tag">${escapeHtml(labels.aTag)}</span><span class="hi-file-name">${escapeHtml(aName)}</span></div>
                                            <div class="hi-file-line"><span class="hi-file-tag">${escapeHtml(labels.hTag)}</span><span class="hi-file-name">${escapeHtml(hName)}</span></div>
                                        </div>
                                        <div class="hi-time">${time}${dur ? ' · ' + dur : ''}</div>
                                    </div>
                                </div>
                                <span class="hi-reload">查看</span>
                            </div>
                            <div class="hi-stats hi-row-stats">
                                <span class="hi-stat ${realCount ? 'critical' : ''}">真 ${realCount}</span>
                                <span class="hi-stat">覆盖 ${coverageCount}</span>
                                <span class="hi-stat ${warningCount ? 'high' : ''}">预警 ${warningCount} · 核 ${blockingWarningCount} / 辅 ${auxiliaryWarningCount}</span>
                                ${staleResult ? '<span class="hi-stat high">旧引擎 · 建议重跑</span>' : ''}
                            </div>
                        </div>
                    `;
                }).join('');
            } catch (e) {
                console.error('loadHistory:', e);
                if (section && count && list) {
                    section.classList.add('has-data');
                    count.textContent = '加载失败';
                    list.dataset.ready = '1';
                    list.innerHTML = '<div class="history-empty">历史记录暂时无法读取，请稍后重试。</div>';
                }
            }
        }

        async function loadJobDetail(jobId) {
            setStatus('加载中...', 'processing');
            try {
                const resp = await fetch(`${API_BASE}/api/jobs/${jobId}`);
                if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                const job = normalizeJob(await resp.json());
                if (!job) return;

                currentJob = job;
                allDiffs = job.diffs || [];
                allCoverage = job.coverage_items || [];
                selectedDiffId = null;
                activeTriage = 'real';

                renderAllViews(job);
                setResultView(defaultResultViewForJob(job));
                document.getElementById('resultsSection').classList.add('active');
                document.getElementById('dashboard').classList.add('active');
                document.getElementById('detailPanel').classList.remove('active');
                document.getElementById('progressSection').classList.remove('active');
                setStatus('历史记录', 'done');
                syncHashToJob();
                showToast(`已加载 ${allDiffs.length} 条差异`, 'success');

                if (jobId) {
                    document.getElementById('downloadXlsx').href = `${API_BASE}/api/jobs/${jobId}/report.xlsx`;
                    document.getElementById('downloadPdf').href = `${API_BASE}/api/jobs/${jobId}/report.pdf`;
                }
            } catch (err) {
                console.error(err);
                setStatus('失败', 'error');
                showToast('加载历史记录失败: ' + err.message, 'error');
            }
        }

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') closeEvidenceReview();
        });

        // ── URL Hash ──
        function syncHashToJob() { if (currentJob && currentJob.job_id) history.replaceState(null, "", "#job=" + currentJob.job_id); }
        async function restoreJobFromHash() {
            const m = window.location.hash.match(/^#job=(.+)$/);
            if (!m) return;
            const jobId = m[1];
            try {
                const resp = await fetch(API_BASE + "/api/jobs/" + encodeURIComponent(jobId));
                if (!resp.ok) return;
                const job = normalizeJob(await resp.json());
                if (!job) return;
                currentJob = job; allDiffs = job.diffs || []; allCoverage = job.coverage_items || [];
                selectedDiffId = null; activeTriage = "real";
                setLaunchPanelVisible(false);
                document.getElementById("resultsSection").classList.add("active");
                document.getElementById("dashboard").classList.add("active");
                document.getElementById("progressSection").classList.remove("active");
                renderAllViews(job);
                setResultView(defaultResultViewForJob(job));
                setStatus("历史记录", "done");
                if (jobId) {
                    document.getElementById("downloadXlsx").href = API_BASE + "/api/jobs/" + jobId + "/report.xlsx";
                    document.getElementById("downloadPdf").href = API_BASE + "/api/jobs/" + jobId + "/report.pdf";
                }
            } catch (e) { console.error("restoreJobFromHash:", e); }
        }
        window.addEventListener("hashchange", () => { if (window.location.hash) restoreJobFromHash(); });

        // Load history on page load
        applyCheckMode();
        loadHistory();
        setTimeout(() => { if (window.location.hash) restoreJobFromHash(); }, 800);
    </script>
</body>
</html>
