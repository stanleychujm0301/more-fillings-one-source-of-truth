# ========== LLM API Key ==========
# DeepSeek — deepseek-v4-pro
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 模型路由偏好 ==========
# 关键数据点抽取/对齐
LLM_EXTRACT_PROVIDER=deepseek
LLM_EXTRACT_MODEL=deepseek-v4-pro

# 准则差异推理（RAG）+ H股中英文翻译语义审查
LLM_REASON_PROVIDER=deepseek
LLM_REASON_MODEL=deepseek-v4-pro

# 多模态图表
VLM_PROVIDER=deepseek
VLM_MODEL=deepseek-v4-pro

# ========== 应用配置 ==========
APP_ENV=dev
LOG_LEVEL=INFO
STORAGE_DIR=./storage
CHROMA_PERSIST_DIR=./storage/chroma
SQLITE_PATH=./storage/ahcc.db

# ========== 性能/限流 ==========
LLM_CONCURRENCY=4
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ========== 演示兜底 ==========
DEMO_CACHE_PATH=./storage/demo_cache.json
DEMO_MODE=false   # 设为 true 时直接读取 demo_cache 秒回放

# ========== 任务执行与稳定性 ==========
JOB_RUNNER=subprocess          # subprocess=每任务独立进程隔离（推荐）｜inline=进程内执行（仅测试用）
JOB_MAX_CONCURRENCY=1          # 同时运行的核查任务数，超出排队
JOB_TIMEOUT_SECONDS=1800       # 单任务硬超时（秒）
JOB_HEARTBEAT_STALE_SECONDS=300  # worker 心跳失联判定阈值（秒）
PARSE_GARBLED_OCR_MAX_PAGES=10     # H股解析乱码页 OCR 兜底页数上限
PARSE_GARBLED_OCR_MAX_SECONDS=120  # 同上，时间上限（秒）
ENABLE_TEXT_OVERLAY_CHECK=true # 文本层叠加篡改检测（检出植入式篡改错误）
