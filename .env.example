# ========== LLM API Keys ==========
# 主推荐：通义千问（DashScope）— 中文金融语料强、多模态可用
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 备选：智谱 GLM-4-Plus — 推理强、多模态
ZHIPUAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxx

# 备选：Kimi K2（Moonshot）— 200k 长上下文兜底
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 备选：DeepSeek — 价格便宜，批量调用
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 模型路由偏好 ==========
# 关键数据点抽取/对齐
LLM_EXTRACT_PROVIDER=qwen
LLM_EXTRACT_MODEL=qwen-plus

# 准则差异推理（RAG）
LLM_REASON_PROVIDER=zhipu
LLM_REASON_MODEL=glm-4-plus

# 多模态图表
VLM_PROVIDER=qwen
VLM_MODEL=qwen-vl-max

# ========== 本地兜底（Ollama）==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ========== 应用配置 ==========
APP_ENV=dev
LOG_LEVEL=INFO
STORAGE_DIR=./storage
CHROMA_PERSIST_DIR=./storage/chroma
SQLITE_PATH=./storage/ahcc.db

# ========== 性能/限流 ==========
LLM_CONCURRENCY=4
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ========== 演示兜底 ==========
DEMO_CACHE_PATH=./storage/demo_cache.json
DEMO_MODE=false   # 设为 true 时直接读取 demo_cache 秒回放
